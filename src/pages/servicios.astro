---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import ServicesFull from '../components/ServicesFull.astro';
import CtaBanner from '../components/CtaBanner.astro';
import Footer from '../components/Footer.astro';
import banner2 from '../assets/image/servicios/banner-services.webp';
import logo from '../assets/image/shared/logos/logo.webp';

const stats = [
  { value: "+10,000", label: "Comprobantes emitidos" },
  { value: "+1,500", label: "Negocios|activos" },
  { value: "99.9%", label: "Disponibilidad" },
  { value: "Soporte", label: "24/7", labelClass: "push-down" },
  { value: "+3 millones", label: "en ventas procesadas" },
];
---

<BaseLayout title="Servicios - NANIVA" description="Conoce todos los servicios de NANIVA: Facturación Electrónica, Catálogo Digital, Sistema Restaurante e Implementación a Medida.">
  <Nav />
  <section class="banner" style={`background-image: url('${banner2.src}');`}>
    <div class="content reveal">
      <h1>Impulsa tu negocio<br />con nuestas<br /><span class="highlight">Soluciones</span></h1>
      <p>Te asesoramos para que tengas el mejor<br />sistema que se adecue para tu NEGOCIO.</p>
      <div class="stats">
        {stats.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class={`stat-label ${s.labelClass ?? ""}`}>
              {s.label.split("|").map((line, idx, arr) => (
                idx < arr.length - 1 ? <>{line}<br /></> : line
              ))}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>
  <ServicesFull />
  <CtaBanner />
  <Footer />
</BaseLayout>

<style>
  .banner {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center 10%;
    background-repeat: no-repeat;
    padding: 8rem 8rem 2rem 4rem;
      

  }
  .content {
    max-width: 540px;
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 1.5rem;
  }
  h1 {
    font-size: clamp(2.5rem, 3.5vw, 3rem);
    font-weight: 798;
    line-height: 1.15;
    color: #0f172a;
    transform: translateY(-4rem);
  }
  .highlight {
    position: relative;
    color: #007bff;
  }
  .highlight::after {
    content: "";
    position: absolute;
    left: -6%;
    right: -6%;
    bottom: -1.4rem;
    height: 1.2rem;
    border-bottom: 4px solid #007bff;
    border-radius: 50%;
    transform: scaleY(-1.5);
  }
  p {
    font-size: 1.4rem;
    font-weight: 650;
    color: #334155;
    transform: translateY(-3rem);
  }
  .stats {
    display: flex;
    gap: 0.5rem;
    flex-wrap: nowrap;
    margin-top: 0.5rem;
  }
  .stat {
    background: rgba(255, 255, 255, 0.9);
    border-radius: 10px;
    padding: 0.5rem 0.6rem;
    text-align: center;
    flex: 1;
    min-width: 0;
  }
  .stat:last-child {
    flex: 1.3;
    padding: 0.5rem 0.9rem;
  }
  .stat:nth-child(1),
  .stat:nth-child(2),
  .stat:nth-child(3) {
    flex: 1.15;
    padding: 0.6rem 0.8rem;
  }
  .stat-value {
    display: block;
    color: #2563eb;
    font-weight: 900;
    font-size: 1rem;
    white-space: nowrap;
  }
  .stat-label {
    display: block;
    color: #64748b;
    font-size: 0.78rem;
    font-weight: 700;
  }
  @media (max-width: 900px) {
    .banner { padding-left: 1.5rem; }
  }
  @media (max-width: 768px) {
    .banner {
      background-position: 70% center;
      min-height: auto;
      padding: 6.5rem 1rem 2rem;
    }
    .content {
      max-width: 100%;
      background: rgba(255, 255, 255, 0.9);
      padding: 1.5rem;
      border-radius: var(--radius);
    }
    .logo { transform: translateY(-1rem); height: 64px; }
    h1 { transform: none; font-size: clamp(1.8rem, 7vw, 2.5rem); }
    p { transform: none; font-size: 1rem; }
    .stats { flex-wrap: wrap; }
    .stat,
    .stat:last-child,
    .stat:nth-child(1),
    .stat:nth-child(2),
    .stat:nth-child(3) {
      flex: 1 1 calc(50% - 0.5rem);
    }
  }
  @media (max-width: 380px) {
    .stat,
    .stat:last-child,
    .stat:nth-child(1),
    .stat:nth-child(2),
    .stat:nth-child(3) {
      flex: 1 1 100%;
    }
  }
</style>
