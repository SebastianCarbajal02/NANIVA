const CATALOGO_ANNUAL_DISCOUNT = 0.2;
function annualPricing(monthly: number) {
  const fullYear = monthly * 12;
  const discounted = Math.round(fullYear * (1 - CATALOGO_ANNUAL_DISCOUNT));
  return { fullYear, discounted, savings: fullYear - discounted };
}

