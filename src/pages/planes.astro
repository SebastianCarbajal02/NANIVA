    { text: "Busqueda RUC/DNI", sub: "(Interconectado con SUNAT/RENIEC)" },
  ],
  support: { text: "SOPORTE PREMIUM", sub: "LLAMADA Y WHATSAPP" },
  cta: "Empezar ahora",
  ctaIcon: "rocket",
};

const catalogoPlans = [
  {
    name: "PLAN NEGOCIO",
    monthly: 79,
    productsNote: "Hasta 300 productos",
    featured: false,
    items: [
      "Catálogo digital integrado al sistema",
      "Creación de catálogos PDF",
      "Portada y fondo personalizados",
      "Banners",
      "Carga masiva de imágenes",
      { text: "Enlace para compartir por WhatsApp", sub: "(cotizaciones enlace pdf)" },
      "Lista de catálogos guardados",
      "Edición básica de catálogos",
      "Soporte",
      "300 Productos (2 x imagen)",
      "Envío masivos por Whatsapp",
    ],
  },
  {
    name: "PLAN EMPRESA",
    monthly: 118,
    productsNote: "Hasta 600 productos (2x imagen)",
    featured: true,
    items: [
      "Catálogo digital integrado al sistema",
      "Creación de catálogos PDF",
      "Portada y fondo personalizados",
      "Edición masiva de productos, categorías, precios y marcas",
      "Cambio de tema / colores / Banners",
      "Más plantillas o estilos de catálogo",
      { text: "Envío masivo por WhatsApp", sub: "(cotizaciones enlace pdf)" },
      "Carga masiva de imágenes",
      "Soporte premium",
    ],
    tag: { label: "NUEVO", text: "Envíos masivos por WhatsApp" },
  },
];

const compareFeatures = [
  { icon: "book", label: "Catálogo digital integrado al sistema", negocio: true, empresa: true },
  { icon: "filetext", label: "Creación de catálogo PDF", negocio: true, empresa: true },
  { icon: "image", label: "Portadas y fondos personalizados", negocio: true, empresa: true },
  { icon: "monitor", label: "Banners", negocio: true, empresa: true },
  { icon: "upload", label: "Carga masiva de imágenes", negocio: true, empresa: true },
  { icon: "whatsapp", label: "Enlace para compartir por WhatsApp", sub: "(cotizaciones o enlace pdf)", negocio: true, empresa: true },
  { icon: "folder", label: "Lista de catálogos guardados", negocio: true, empresa: true },
  { icon: "edit", label: "Edición básica de catálogos", negocio: true, empresa: true },
  { icon: "headset", label: "Soporte", negocio: true, empresa: true },
  { icon: "box", label: "300 Productos (2K Imágenes)", negocio: true, empresa: true },
  { icon: "send", label: "Envío masivo por WhatsApp", negocio: false, empresa: true, empresaTag: "NUEVO" },
];

const trustBadges = [
  { icon: "shield", title: "Sin contratos forzosos", desc: "Planes flexibles sin permanencia" },
  { icon: "refresh", title: "Cambia o cancela cuando quieras", desc: "Tú decides, sin complicaciones" },
  { icon: "lock", title: "Pago 100% seguro", desc: "Tus datos siempre protegidos" },
  { icon: "headset", title: "Soporte especializado", desc: "Estamos para ayudarte" },
];

const negociosCategories = [
  { img: iconNegocioFerreterias, label: "Ferreterías" },
  { img: iconNegocioDistribuidoras, label: "Distribuidoras" },
  { img: iconNegocioTiendas, label: "Tiendas" },
  { img: iconNegocioMinimarkets, label: "Minimarkets" },
  { img: iconNegocioImportadores, label: "Importadores" },
  { img: iconNegocioMayoristas, label: "Mayoristas" },
];


// Placeholder — se completará con contenido real más adelante.
const otherProducts = [
  {
    anchor: "ia",
    badge: "INTELIGENCIA DE NEGOCIO",
    title: "IA NANIVA",
    subtitle: "Predicciones y recomendaciones basadas en tus datos.",
    items: ["Predicción de ventas", "Recomendaciones de stock", "Alertas inteligentes", "Reportes automáticos"],
  },
];
---
<BaseLayout title="Planes - NANIVA" description="Elige el plan NANIVA ideal para tu negocio.">
  <Nav />
  <section class="banner" style={`background-image: url('${banner.src}');`}>
    <div class="content reveal">
      <div class="logo-spacer" aria-hidden="true"></div>
      <h1>Descubre nuestros<br /><span class="highlight">PLANES</span></h1>
      <p>La solución perfecta para<br />hacer <span class="p-highlight">crecer tu negocio</span></p>
      <div class="plan-features">
        {planFeatures.map((f) => (
          <div class="plan-feature">
            <span class="plan-feature-icon icon-bounce">
              <img src={f.iconImg.src} alt={f.title} class="plan-feature-icon-img" />
            </span>
          </div>
        ))}
      </div>
      <div class="banner-note">
        <span class="note-icon">⭐</span>
        <span>Elige el plan ideal y lleva tu negocio<br /><strong>al siguiente nivel ↗</strong></span>
      </div>
    </div>
    <img src={bannerPersona.src} alt="" class="banner-persona" aria-hidden="true" />
  </section>

  <section class="products-section">
    <div class="container">
      <div class="products-head reveal">
        <span class="erp-badge">ELIGE TU SOLUCIÓN</span>
        <h2>Elige la solución ideal<br />para <span class="p-highlight">hacer crecer tu negocio</span></h2>
        <p>Selecciona el módulo que mejor se adapta a tus necesidades<br />y comienza a <span class="products-head-link">transformar tu empresa</span>.</p>
      </div>
      <div class="products-grid">
        {products.map((product, i) => (
          <a
            href={`#${product.anchor}`}
            class={`product-card reveal${i === 0 ? " is-active" : ""}`}
            data-target={product.anchor}
            style={`transition-delay:${i * 0.1}s`}
          >
            <img src={product.icon.src} alt={product.title} class="product-icon" />
            <h3>{product.title}</h3>
            <p>{product.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="erp" class="erp-detail product-detail is-active">
    <div class="container erp-hero">
      <div class="erp-hero-copy reveal">
        <span class="erp-badge">
          <span set:html={icon("layers", "#2563eb", 15)} />
          PLATAFORMA TODO EN UNO
        </span>
        <h2>ERP <span class="p-highlight">NANIVA</span></h2>
        <p class="erp-hero-sub">El sistema completo para administrar tu empresa en un solo lugar.</p>

        <div class="price-card">
          <div class="price-main">
            <span class="price-label">Desde</span>
            <span class="price-value"><span class="price-S">S/</span> 79<span class="price-unit">/mes</span></span>
          </div>
          <span class="price-note">Todo lo que necesitas<br />para operar y crecer.</span>
        </div>

        <div class="checklist-grid">
          {heroChecklist.map((col) => (
            <ul class="checklist-col">
              {col.map((item) => (
                <li><span set:html={icon("check")} />{item}</li>
              ))}
            </ul>
          ))}
        </div>

        <div class="erp-cta">
          <a href="/contacto" class="btn-primary hover-pop">Comenzar ahora</a>
          <a href="/contacto" class="btn-outline hover-pop">Solicitar demostración</a>
        </div>

        <div class="secure-note">
          <span set:html={icon("shield")} />
          Tus datos están seguros y protegidos
        </div>
      </div>

      <div class="erp-hero-media reveal">
        <img src={erpMockup.src} alt="Dashboard ERP Naniva" class="erp-mockup-img" />
      </div>
    </div>

    <div class="container erp-stats-bar reveal">
      {heroStats.map((s) => (
        <div class="stat-pill">
          <span class="stat-pill-icon" set:html={icon(s.icon)} />
          <div>
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="container erp-modules">
      <div class="modules-head reveal">
        <span class="erp-badge alt">TU EMPRESA, TOTALMENTE ORGANIZADA</span>
        <h2>Módulos diseñados para<br /><span class="p-highlight">cada área</span> de tu negocio</h2>
        <p>Todo lo que necesitas en un solo sistema. Más control, más eficiencia, más crecimiento.</p>
        <a href="/contacto" class="btn-primary hover-pop modules-head-cta">Comenzar ahora →</a>
      </div>

      <div class="modules-layout">
        <div class="modules-grid">
          {modules.map((m, i) => (
            <div class="module-card reveal" style={`transition-delay:${i * 0.05}s`}>
              <div class="module-header-row">
                <span class="module-icon" style={`background:${m.bg}`}>
                  <span
                    class="module-icon-mask"
                    role="img"
                    aria-label={m.title}
                    style={`background-color:${m.color}; -webkit-mask-image:url('${m.iconImg.src}'); mask-image:url('${m.iconImg.src}');`}
                  ></span>
                </span>
                <h3>{m.title}</h3>
              </div>
              <ul>
                {m.items.map((it) => (
                  <li><span set:html={icon("check")} />{it}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <aside class="plan-sidebar reveal">
          <div class="plan-sidebar-head">
            <strong>Tu plan, tu crecimiento</strong>
            <span class="plan-sidebar-rule"></span>
            <span class="plan-sidebar-sub">Todo lo que necesitas<br />para crecer sin límites.</span>
            <svg class="plan-sidebar-chart" viewBox="0 0 220 90" preserveAspectRatio="none">
              <path d="M0 75 L40 60 L75 68 L110 40 L150 45 L190 15 L220 8" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
              <circle cx="220" cy="8" r="5" fill="#38bdf8" />
            </svg>
          </div>

          <div class="plan-sidebar-list">
            {planSidebarStats.map((s, idx) => (
              <div class="plan-sidebar-item" style={idx < planSidebarStats.length - 1 ? "" : "border-bottom:none"}>
                <span class="plan-sidebar-icon" style={`background:${s.bg}`} set:html={icon(s.icon, s.color, 22)} />
                <div class="plan-sidebar-text">
                  {s.value && <strong class="plan-sidebar-value" style={`color:${s.color}`}>{s.value}</strong>}
                  <span class="plan-sidebar-label">{s.label}</span>
                  <span class="plan-sidebar-sub-label">{s.sub}</span>
                </div>
              </div>
            ))}
          </div>

          <a href="/contacto" class="btn-primary hover-pop plan-sidebar-btn">Expande tu plan →</a>

        </aside>
      </div>
    </div>

    <div class="container">
      <div class="integration-banner reveal">
        <span class="integration-icon">
          <img src={logoInicio.src} alt="Naniva" class="integration-icon-img" />
        </span>
        <div class="integration-copy">
          <strong>Todos los módulos trabajan juntos en perfecta integración</strong>
          <span>Información centralizada, procesos automatizados y decisiones inteligentes.</span>
        </div>
        {integrationPoints.map((p) => (
          <div class="integration-point">
            <span
              class="integration-point-icon"
              style={`-webkit-mask-image:url('${p.iconImg.src}'); mask-image:url('${p.iconImg.src}');`}
            ></span>
            {p.title}
          </div>
        ))}
      </div>

      <div class="extra-modules reveal">
        <h3>Conoce nuestros módulos adicionales</h3>
        <p>Añade los módulos que tu negocio necesita</p>
        <div class="extra-modules-grid">
          {extraModules.map((m) => (
            <div class="extra-module-card">
              <div class="extra-module-header">
                <span class="module-icon-extra">
                  <img src={m.iconImg.src} alt={m.title} class="module-icon-img-sm" />
                </span>
                <div class="extra-module-info">
                  <strong>{m.title}</strong>
                  <span>{m.desc}</span>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="banner-plan-cta">
      <img src={bannerPlan.src} alt="¿Listo para transformar tu empresa? Solicita una demostración personalizada." class="banner-plan-img" />
      <div class="banner-plan-cta-overlay">
        <span class="banner-plan-sub">Sin compromiso. En menos de 30 minutos.</span>
      </div>
    </div>
  </section>

  <section id="catalogo-digital" class="erp-detail catalogo-detail product-detail">
    <div class="container erp-hero">
      <div class="erp-hero-copy reveal">
        <span class="erp-badge catalogo-badge">
          <span set:html={icon("store", "#16a34a", 15)} />
          CATÁLOGO EN WHATSAPP
        </span>
        <h2>Catálogo <span class="p-highlight catalogo-highlight">Digital</span></h2>
        <p class="erp-hero-sub">Vender más a través de todos los canales. Comparte tu catálogo, recibe pedidos y convierte consultas en ventas.</p>

        <div class="catalogo-features">
          {catalogoFeatures.map((f) => (
            <img src={f.img.src} alt={f.alt} class="catalogo-feature-img" />
          ))}
        </div>

        <div class="erp-cta">
          <a href="/contacto" class="btn-primary catalogo-btn-primary hover-pop">Comenzar ahora</a>
          <a href="/contacto" class="btn-outline catalogo-btn-outline hover-pop">Solicitar demostración</a>
        </div>
      </div>

      <div class="erp-hero-media reveal">
        <img src={catalogoMockup.src} alt="Catálogo Digital Naniva - pedidos por WhatsApp" class="erp-mockup-img catalogo-mockup-img" />
      </div>
    </div>

    <div class="container catalogo-pricing reveal" data-billing-scope="catalogo">
      <div class="catalogo-pricing-head">
        <h2><span set:html={icon("bag", "#16a34a", 26)} />Catálogo Digital</h2>
        <p>Planes diseñados para negocios que quieren vender más por WhatsApp y otros canales.</p>
      </div>

      <div class="billing-toggle">
        <button type="button" class="billing-toggle-btn is-active" data-billing-btn="mensual">Mensual</button>
        <button type="button" class="billing-toggle-btn" data-billing-btn="anual">Anual</button>
      </div>
      <p class="billing-savings-note" data-billing-note="anual">Ahorra {Math.round(CATALOGO_ANNUAL_DISCOUNT * 100)}% pagando anual</p>

      <div class="catalogo-plans-grid billing-panel is-active" data-billing-panel="mensual">
        {catalogoPlans.map((plan) => (
          <div class={`plan-card${plan.featured ? " plan-card-featured" : ""}`}>
            {plan.badge && <span class="plan-badge">★ {plan.badge}</span>}
            <h3 class="plan-name">{plan.name}</h3>
            <div class="plan-price-block">
              <div class="plan-price"><span class="plan-price-S">S/</span> {plan.monthly}<span class="plan-price-unit">/mes</span></div>
            </div>
            {plan.featured ? (
              <span class="plan-products-note"><span set:html={icon("box", "#16a34a", 16)} /> {plan.productsNote}</span>
            ) : (
              <span class="plan-products-pill">{plan.productsNote}</span>
            )}
            <ul class="plan-items">
              {plan.items.map((it) => (
                <li>
                  <span set:html={icon("check")} />
                  <span>
                    {typeof it === "string" ? it : (<>{it.text}<br /><span class="plan-item-sub">{it.sub}</span></>)}
                  </span>
                </li>
              ))}
            </ul>
            {plan.tag && (
              <div class="plan-tag-row">
                <span class="plan-tag-badge">{plan.tag.label}</span>
                <span class="plan-tag-text">{plan.tag.text}</span>
              </div>
            )}
            <a href="/contacto" class={`plan-cta-btn hover-pop${plan.featured ? " plan-cta-btn-filled" : ""}`}>Elegir plan</a>
          </div>
        ))}
      </div>

      <div class="catalogo-plans-grid billing-panel" data-billing-panel="anual">
        {catalogoPlans.map((plan) => {
          const { fullYear, discounted, savings } = annualPricing(plan.monthly);
          return (
            <div class={`plan-card${plan.featured ? " plan-card-featured" : ""}`}>
              {plan.badge && <span class="plan-badge">★ {plan.badge}</span>}
              <h3 class="plan-name">{plan.name}</h3>
              <div class="plan-price-block">
                <span class="plan-price-strike">S/ {fullYear.toLocaleString("es-PE")}</span>
                <div class="plan-price"><span class="plan-price-S">S/</span> {discounted.toLocaleString("es-PE")}<span class="plan-price-unit">/año</span></div>
                <span class="plan-savings-note">Ahorra S/ {savings.toLocaleString("es-PE")} al año</span>
              </div>
              {plan.featured ? (
                <span class="plan-products-note"><span set:html={icon("box", "#16a34a", 16)} /> {plan.productsNote}</span>
              ) : (
                <span class="plan-products-pill">{plan.productsNote}</span>
              )}
              <ul class="plan-items">
                {plan.items.map((it) => (
                  <li>
                    <span set:html={icon("check")} />
                    <span>
                      {typeof it === "string" ? it : (<>{it.text}<br /><span class="plan-item-sub">{it.sub}</span></>)}
                    </span>
                  </li>
                ))}
              </ul>
              {plan.tag && (
                <div class="plan-tag-row">
                  <span class="plan-tag-badge">{plan.tag.label}</span>
                  <span class="plan-tag-text">{plan.tag.text}</span>
                </div>
              )}
              <a href="/contacto" class={`plan-cta-btn hover-pop${plan.featured ? " plan-cta-btn-filled" : ""}`}>Elegir plan</a>
            </div>
          );
        })}
      </div>
    </div>

    <div class="container catalogo-compare reveal">
      <div class="catalogo-pricing-head">
        <h2 class="compare-title">COMPARA LOS <span class="p-highlight catalogo-highlight">PLANES</span></h2>
        <p>Elige el plan ideal para impulsar tu negocio</p>
      </div>

      <div class="compare-layout">
        <div class="compare-table">
          <div class="compare-row compare-row-head">
            <div class="compare-cell compare-cell-label">
              <span class="compare-label-title">CARACTERÍSTICAS</span>
            </div>
            <div class="compare-cell compare-cell-plan">
              <span class="compare-plan-name">{catalogoPlans[0].name}</span>
              <div class="compare-plan-price"><span class="plan-price-S">S/</span> {catalogoPlans[0].monthly}<span class="plan-price-unit">/mes</span></div>
              <span class="plan-products-pill">{catalogoPlans[0].productsNote}</span>
            </div>
            <div class="compare-cell compare-cell-plan compare-cell-featured">
              <span class="compare-plan-name">{catalogoPlans[1].name}</span>
              <div class="compare-plan-price"><span class="plan-price-S">S/</span> {catalogoPlans[1].monthly}<span class="plan-price-unit">/mes</span></div>
              <span class="plan-products-pill">{catalogoPlans[1].productsNote}</span>
            </div>
          </div>

          {compareFeatures.map((f) => (
            <div class="compare-row">
              <div class="compare-cell compare-cell-label">
                <span class="compare-label-icon" set:html={icon(f.icon, "#64748b", 15)} />
                <span class="compare-label-text">
                  {f.label}
                  {f.sub && <span class="compare-label-sub">{f.sub}</span>}
                </span>
              </div>
              <div class="compare-cell compare-cell-value">
                {f.negocio ? <span class="compare-check" set:html={icon("check", "#16a34a", 16)} /> : <span class="compare-dash">—</span>}
              </div>
              <div class="compare-cell compare-cell-value compare-cell-featured">
                {f.empresa ? (
                  f.empresaTag ? (
                    <span class="compare-new-tag">
                      <span class="plan-tag-badge">{f.empresaTag}</span>
                      {f.label}
                    </span>
                  ) : (
                    <span class="compare-check" set:html={icon("check", "#16a34a", 16)} />
                  )
                ) : (
                  <span class="compare-dash">—</span>
                )}
              </div>
            </div>
          ))}

          <div class="compare-row compare-row-cta">
            <div class="compare-cell compare-cell-label"></div>
            <div class="compare-cell compare-cell-plan">
              <a href="/contacto" class="plan-cta-btn hover-pop">Elegir plan</a>
            </div>
            <div class="compare-cell compare-cell-plan compare-cell-featured">
              <a href="/contacto" class="plan-cta-btn plan-cta-btn-filled hover-pop">Elegir plan</a>
            </div>
          </div>
        </div>

        <aside class="compare-side">
          <span class="compare-side-icon" set:html={icon("help", "#2563eb", 40)} />
          <h3>¿Necesitas más productos?</h3>
          <p>Puedes ampliar la cantidad de productos cuando tu negocio lo necesite.</p>
          <a href="/contacto" class="btn-primary hover-pop compare-side-btn">Más información</a>
        </aside>
      </div>

      <div class="trust-badges-row reveal">
        {trustBadges.map((t) => (
          <div class="trust-badge">
            <span class="trust-badge-icon" set:html={icon(t.icon, "#16a34a", 22)} />
            <div class="trust-badge-text">
              <strong>{t.title}</strong>
              <span>{t.desc}</span>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="container catalogo-audience reveal">
      <div class="catalogo-pricing-head">
        <h2 class="audience-title"><span class="audience-dash"></span> Ideal para negocios <span class="p-highlight catalogo-highlight">como el tuyo</span> <span class="audience-dash"></span></h2>
        <p>Nuestros planes se adaptan a todo tipo de negocio. Elige el que mejor se ajuste a tus necesidades.</p>
      </div>

      <div class="audience-carousel">
        <button type="button" class="audience-nav" aria-label="Anterior" data-carousel-prev>‹</button>
        <div class="audience-track" data-carousel-track>
          {negociosCategories.map((c) => (
            <div class="audience-card">
              <img src={c.img.src} alt={c.label} class="audience-card-icon" />
              <span class="audience-card-label">{c.label}</span>
              <span class="audience-card-underline"></span>
            </div>
          ))}
          <div class="audience-card catalogo-extra-audience-card">
            <img src={iconRestauranteExtra15.src} alt="Farmacias" class="audience-card-icon" />
            <span class="audience-card-label">Farmacias</span>
            <span class="audience-card-underline"></span>
          </div>
          <div class="audience-card catalogo-extra-audience-card">
            <img src={iconRestauranteExtra16.src} alt="Jugueterías" class="audience-card-icon" />
            <span class="audience-card-label">Jugueterías</span>
            <span class="audience-card-underline"></span>
          </div>
        </div>
        <button type="button" class="audience-nav" aria-label="Siguiente" data-carousel-next>›</button>
      </div>
    </div>

    <div class="container">
      <a href="/contacto" class="catalogo-cta-banner reveal">
        <img src={catalogoCtaBanner.src} alt="Empieza a vender por WhatsApp hoy mismo" class="catalogo-cta-banner-img" />
      </a>
    </div>
  </section>

  <section id="ecommerce" class="erp-detail restaurante-detail product-detail">
    <div class="container erp-hero">
      <div class="erp-hero-copy reveal">
