<script>
  function initProductSwitcher() {
    const cards = document.querySelectorAll<HTMLAnchorElement>(".product-card[data-target]");
    const details = document.querySelectorAll<HTMLElement>(".product-detail");

    function showDetail(target: string) {
      let matched = false;
      details.forEach((detail) => {
        const isMatch = detail.id === target;
        detail.classList.toggle("is-active", isMatch);
        if (isMatch) matched = true;
      });
      cards.forEach((card) => {
        card.classList.toggle("is-active", card.dataset.target === target);
      });
      return matched;
    }

    cards.forEach((card) => {
      card.addEventListener("click", (e) => {
        const target = card.dataset.target;
        if (!target) return;
        e.preventDefault();
        if (showDetail(target)) {
          history.replaceState(null, "", `#${target}`);
          document.getElementById(target)?.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });

    const initialHash = window.location.hash.replace("#", "");
    if (initialHash) showDetail(initialHash);
  }

  function initBillingToggle() {
    const buttons = document.querySelectorAll<HTMLButtonElement>("[data-billing-btn]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const billing = btn.dataset.billingBtn;
        if (!billing) return;
        const scope = btn.closest<HTMLElement>("[data-billing-scope]");
        if (!scope) return;

        scope.querySelectorAll<HTMLButtonElement>("[data-billing-btn]").forEach((b) => b.classList.toggle("is-active", b.dataset.billingBtn === billing));
        scope.querySelectorAll<HTMLElement>("[data-billing-panel]").forEach((panel) => {
          panel.classList.toggle("is-active", panel.dataset.billingPanel === billing);
        });
        scope.querySelectorAll<HTMLElement>("[data-billing-note]").forEach((note) => {
          note.classList.toggle("is-active", note.dataset.billingNote === billing);
        });
      });
    });
  }

  function initAudienceCarousel() {
    document.querySelectorAll<HTMLElement>("[data-carousel-track]").forEach((track) => {
      const wrapper = track.closest(".audience-carousel");
      if (!wrapper) return;
      const prevBtn = wrapper.querySelector<HTMLButtonElement>("[data-carousel-prev]");
      const nextBtn = wrapper.querySelector<HTMLButtonElement>("[data-carousel-next]");
      const scrollAmount = () => track.clientWidth * 0.8;

      prevBtn?.addEventListener("click", () => {
        track.scrollBy({ left: -scrollAmount(), behavior: "smooth" });
      });
      nextBtn?.addEventListener("click", () => {
        track.scrollBy({ left: scrollAmount(), behavior: "smooth" });
      });
    });
  }

  initProductSwitcher();
  initBillingToggle();
  initAudienceCarousel();
  document.addEventListener("astro:after-swap", () => {
    initProductSwitcher();
    initBillingToggle();
    initAudienceCarousel();
  });
</script>


