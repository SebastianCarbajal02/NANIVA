---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import banner from '../assets/image/banner-plan-03.png';
import bannerPersona from '../assets/image/banner-plan-persona-03.png';
import iconERP from '../assets/image/icondd-05.png';
import iconCatalogo from '../assets/image/icondd-06.png';
import iconEcommerce from '../assets/image/icondd-07.png';
import iconIA from '../assets/image/icondd-08.png';

const planFeatures = [
  { icon: "🏷️", title: "Planes flexibles", desc: "para cada necesidad" },
  { icon: "📈", title: "Impulsa", desc: "tu crecimiento" },
  { icon: "🛡️", title: "Seguridad y", desc: "confianza" },
  { icon: "👥", title: "Soporte", desc: "especializado" },
];

const products = [
  { icon: iconERP, title: "ERP", desc: "Sistema principal" },
  { icon: iconCatalogo, title: "Catálogo Digital", desc: "Catálogo en WhatsApp" },
  { icon: iconEcommerce, title: "Ecommerce", desc: "Tienda online" },
  { icon: iconIA, title: "IA", desc: "Inteligencia de negocio" },
];
---
<BaseLayout title="Planes - NANIVA" description="Elige el plan NANIVA ideal para tu negocio.">
  <Nav />
  <section class="banner" style={`background-image: url('${banner.src}');`}>
    <div class="content reveal">
      <div class="logo-spacer" aria-hidden="true"></div>
      <h1>Descubre nuestros<br /><span class="highlight">PLANES</span></h1>
      <p>La solución perfecta para<br />hacer <span class="p-highlight">crecer tu negocio</span></p>
      <div class="plan-features">
        {planFeatures.map((f) => (
          <div class="plan-feature">
            <span class="plan-feature-icon icon-bounce">{f.icon}</span>
            <span class="plan-feature-label">{f.title}<br />{f.desc}</span>
          </div>
        ))}
      </div>
      <div class="banner-note">
        <span class="note-icon">⭐</span>
        <span>Elige el plan ideal y lleva tu negocio<br /><strong>al siguiente nivel ↗</strong></span>
      </div>
    </div>
    <img src={bannerPersona.src} alt="" class="banner-persona" aria-hidden="true" />
  </section>

  <section class="products-section">
    <div class="container">
      <div class="products-grid">
        {products.map((product, i) => (
          <div class="product-card reveal" style={`transition-delay:${i * 0.1}s`}>
            <img src={product.icon.src} alt={product.title} class="product-icon" />
            <h3>{product.title}</h3>
            <p>{product.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .banner {
    position: relative;
    min-height: 100vh;
    overflow-x: hidden;
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: 6.5rem 1.5rem 1.5rem 4rem;
  }
  .banner-persona {
    position: absolute;
    right: 0;
    bottom: 0;
    height: 95vh;
    width: auto;
    object-fit: contain;
    z-index: 1;
    pointer-events: none;
    transform: translateY(-2rem);
  }
  .content {
    max-width: 540px;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.65rem;
  }
  .logo {
    height: 92px;
    width: auto;
    object-fit: contain;
   transform: translateY(-4rem);
  }
  .logo-spacer {
    height: 4rem;
    width: 1px;
  }
  .content h1 {
    font-size: clamp(3.3rem, 3.5vw, 3rem);
    font-weight: 798;
    line-height: 1.15;
    color: #0f172a;
    transform: translateY(-2rem);;
  }
  .content .highlight {
    color: #007bff;
  }
  .content p {
    font-size: 1.3rem;
    font-weight: 650;
    color: #334155;
  }
  .p-highlight {
    color: #2563eb;
  }
  .plan-features {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }
  .plan-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    width: 76px;
    text-align: center;
  }
  .plan-feature-icon {
    width: 72px;
    height: 72px;
    border-radius: 16px;
    background: white;
    box-shadow: 0 4px 10px rgba(15,23,42,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
  }
  .plan-feature-label {
    font-size: 0.72rem;
    font-weight: 640;
    color: #0f172a;
    line-height: 1.3;
  }
  .banner-note {
    margin-top: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(219, 234, 254, 0.9);
    padding: 0.75rem 1.25rem;
    border-radius: 14px;
    font-size: 0.85rem;
    color: #1e3a8a;
  }
  .note-icon {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #2563eb;
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 1rem;
  }
  .banner-note strong { color: #2563eb; }

  .products-section {
    padding: 3.5rem 2rem;
    background: #ffffff;
  }
  .products-section .container {
    max-width: 1400px;
    margin: 0 auto;
  }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .product-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 1.75rem 1.25rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    transition: all 0.3s ease;
    cursor: pointer;
  }
  .product-card:first-child {
    border: 2px solid #2563eb;
    background: #f0f7ff;
  }
  .product-card:hover {
    border-color: #2563eb;
    box-shadow: 0 8px 24px rgba(37, 99, 235, 0.15);
    transform: translateY(-2px);
  }
  .product-icon {
    width: 72px;
    height: 72px;
    object-fit: contain;
  }
  .product-card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
    line-height: 1.3;
  }
  .product-card p {
    font-size: 0.8rem;
    color: #64748b;
    margin: 0;
    line-height: 1.2;
  }

  @media (max-width: 1100px) {
    .products-grid { grid-template-columns: repeat(4, 1fr); gap: 1rem; max-width: 100%; }
    .product-card { padding: 1.5rem 1rem; }
    .product-icon { width: 64px; height: 64px; }
  }
  @media (max-width: 900px) {
    .products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .products-grid { grid-template-columns: 1fr; }
    .products-section { padding: 2.5rem 1rem; }
    .product-card { padding: 1.5rem 1rem; }
    .product-icon { width: 60px; height: 60px; }
    .product-card h3 { font-size: 0.95rem; }
  }

  @media (max-width: 900px) {
    .banner { padding-left: 1.5rem; }
  }
  @media (max-width: 768px) {
    .banner-persona { display: none; }
    .banner {
      background-position: 70% center;
      min-height: auto;
      padding: 6.5rem 1rem 2rem;
    }
    .content {
      max-width: 100%;
      background: rgba(255, 255, 255, 0.9);
      padding: 1.5rem;
      border-radius: var(--radius);
    }
    .logo { transform: translateY(-1rem); height: 64px; }
    .content h1 { transform: none; font-size: clamp(1.8rem, 7vw, 2.5rem); }
    .content p { font-size: 1rem; }
    .plan-features { justify-content: center; gap: 0.75rem; }
    .plan-feature { width: 64px; }
    .plan-feature-icon { width: 56px; height: 56px; font-size: 1.5rem; }
    .banner-note { flex-wrap: wrap; }
  }
</style>