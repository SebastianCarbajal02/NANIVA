---
import dashboardImg from '../assets/image/Dashboard.webp';
import iconBrainImg from '../assets/image/icomvid-15.png';
import iconClockImg from '../assets/image/icomvid-16.png';
import iconCartImg from '../assets/image/icomvid-17.png';
import iconStatBoltImg from '../assets/image/final mqta-18.png';
import iconStatBrainImg from '../assets/image/final mqta-19.png';
import iconStatMonitorImg from '../assets/image/final mqta-20.png';
import iconStatCloudImg from '../assets/image/final mqta-21.png';
import iconCarroImg from '../assets/image/carro.png';
import iconCajaImg from '../assets/image/caja-negra.png';
import iconCerebroImg from '../assets/image/cerebro.png';

const features = [
  { iconImg: iconClockImg, label: "Dashboard en tiempo real" },
  { iconImg: iconBrainImg, label: "IA tomando decisiones" },
  { iconImg: iconCartImg, label: "Compras inteligentes" },
];

const stats = [
  { iconImg: iconStatBoltImg, value: "90 segundos", desc: "Demo rápida y directa." },
  { iconImg: iconStatBrainImg, value: "IA integrada", desc: "Recomendaciones inteligentes." },
  { iconImg: iconStatMonitorImg, value: "Sistema real", desc: "Datos reales. Sin simulaciones." },
  { iconImg: iconStatCloudImg, value: "100% en la nube", desc: "Accede desde cualquier lugar." },
];

const previewCards = [
  { iconImg: iconCarroImg, bg: "#dcfce7", color: "#16a34a", title: "Ventas", desc: "Gestiona tus ventas y aumenta ingresos." },
  { iconImg: iconCajaImg, bg: "#dbeafe", color: "#2563eb", title: "Inventario", desc: "Controla tu stock en tiempo real." },
  { iconImg: iconCerebroImg, bg: "#f3e8ff", color: "#9333ea", title: "IA Inteligente", desc: "Decisiones más inteligentes con análisis predictivo." },
];
---
<section id="demo" class="demo-video">
  <div class="container">
    <div class="tag">🚀 TRANSFORMA TU EMPRESA</div>
    <h2>La plataforma que impulsa<br /><span class="highlight">tu negocio, en tiempo real</span></h2>
    <p class="subtitle">Lo que verás en esta demostracion</p>

    <div class="preview-cards">
      {previewCards.map((c) => (
        <div class="preview-card">
          <span class="preview-icon" style={`background:${c.bg}`}>
            <span class="preview-icon-mask" style={`background-color:${c.color}; mask-image:url(${c.iconImg.src}); -webkit-mask-image:url(${c.iconImg.src});`}></span>
          </span>
          <div>
            <strong style={`color:${c.color}`}>{c.title}</strong>
            <p>{c.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="demo-panel reveal">
      <div class="demo-copy">
        <span class="badge">▶ MIRA NANIVA EN ACCIÓN</span>
        <h3>Mira <span class="highlight">Naniva</span><br />en acción</h3>
        <p class="highlight-box">
          Descubre cómo una sola plataforma conecta ventas, inventario, facturación e inteligencia artificial para ayudarte a tomar mejores decisiones.
          <span class="highlight-strong">Todo en menos de 90 segundos.</span>
        </p>
        <ul class="feature-list">
          {features.map((f) => (
            <li>
              <img src={f.iconImg.src} alt="" class="feature-icon-img" />
              <span class="feature-label">{f.label}</span>
            </li>
          ))}
        </ul>
        <a href="#video" class="cta hover-pop">▶ Ver demo (90 s)</a>
      </div>

      <div class="demo-video-wrap">
        <img src={dashboardImg.src} alt="Naniva en acción" class="demo-screen" />
        <button type="button" class="play-btn" aria-label="Reproducir demo">▶</button>
        <div class="video-controls">
          <span class="video-time">0:00 / 1:30</span>
          <div class="video-bar"><span class="video-progress"></span></div>
          <span class="video-icons">🔊 ⚙ ⛶</span>
        </div>
      </div>
    </div>

    <div class="stats-bar">
      <div class="stats-grid">
        {stats.map((st, i) => (
          <div class="stat-item reveal" style={`transition-delay:${i * 0.08}s`}>
            <img src={st.iconImg.src} alt="" class="stat-icon-img" />
            <div>
              <h4>{st.value}</h4>
              <p>{st.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .demo-video {
    padding: 4rem 0;
    background: #f8fafc;
  }
  .demo-video .container {
    max-width: 1600px;
  }
  .tag {
    text-align: center;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  h2 {
    text-align: center;
    font-size: clamp(1.8rem, 3.5vw, 3rem);
    font-weight: 800;
    line-height: 1.25;
    margin-bottom: 1rem;
    color: #0f172a;
  }
  .highlight { color: #2563eb; }
  .subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
    line-height: 1.6;
    font-size: 1.5rem;
  }

  .demo-panel {
    display: flex;
    align-items: center;
    gap: 3rem;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .demo-copy {
    flex: 1;
    min-width: 300px;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: #eaf1ff;
    color: #2563eb;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.04em;
    padding: 0.4rem 0.9rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .demo-copy h3 {
    font-size: clamp(1.8rem, 3.4vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    color: #0f172a;
    margin-bottom: 1rem;
     font-size: 3.5rem;
  }
  .demo-copy p {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
     font-weight: 600;
  }
  .highlight-box {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.25rem 1.2rem;
    max-width: 440px;
  }
  .highlight-strong {
    display: block;
    color: #2563eb;
    font-weight: 800;
    margin-top: 0.5rem;
  }
  .preview-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto 2.5rem;
  }
  .preview-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .preview-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .preview-icon-mask {
    display: block;
    width: 60%;
    height: 60%;
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
  }
  .preview-card strong {
    display: block;
    font-size: 0.95rem;
    font-weight: 800;
    margin-bottom: 0.2rem;
  }
  .preview-card p {
    font-size: 0.78rem;
    color: var(--color-text-muted);
  }
  @media (max-width: 700px) {
    .preview-cards { grid-template-columns: 1fr; }
  }
  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .feature-icon-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .feature-label {
    font-weight: 700;
    font-size: 1rem;
    color: #1e293b;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #2563eb;
    color: white;
    padding: 0.9rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    font-size: 1rem;
  }

  .demo-video-wrap {
    position: relative;
    flex: 1.3;
    min-width: 420px;
    border-radius: 16px;
    overflow: hidden;
    background: #0f172a;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.25);
  }
  .demo-screen {
    width: 100%;
    height: auto;
    display: block;
  }
  .play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 84px;
    height: 84px;
    border-radius: 999px;
    background: #2563eb;
    color: white;
    border: 6px solid rgba(255, 255, 255, 0.9);
    font-size: 1.6rem;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(37, 99, 235, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .video-controls {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(0deg, rgba(0,0,0,0.75), transparent);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: white;
    font-size: 0.8rem;
  }
  .video-bar {
    flex: 1;
    height: 4px;
    background: rgba(255, 255, 255, 0.3);
    border-radius: 999px;
    overflow: hidden;
  }
  .video-progress {
    display: block;
    width: 2%;
    height: 100%;
    background: white;
  }

  .stats-bar {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 0.5rem 1.5rem;
  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .stat-icon-img {
    width: 130px;
    height: 130px;
    object-fit: contain;
    flex-shrink: 0;
  }
  .stat-item h4 { font-size: 0.95rem; font-weight: 800; color: #0f172a; margin-bottom: 0.15rem; }
  .stat-item p { font-size: 0.78rem; color: var(--color-text-muted); }

  @media (max-width: 1100px) {
    .demo-video-wrap { min-width: 100%; }
  }
  @media (max-width: 900px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .demo-panel { flex-direction: column; }
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>
