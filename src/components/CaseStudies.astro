  .stat-item.in-view:nth-child(4) h4 { animation-delay: 0.55s; }
  @keyframes stat-count {
    0% { transform: scale(0.5); opacity: 0; }
    50% { transform: scale(1.2); color: #2563eb; }
    100% { transform: scale(1); opacity: 1; color: #0f172a; }
  }

  /* --- 8. Logo icon entrance + hover --- */
  .logoicon {
    width: 100%;
    height: 100px;
    margin: auto;
    object-fit: contain;
    transform: scale(0.6) rotate(-10deg);
    opacity: 0;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease;
    cursor: pointer;
  }
  .case-card.in-view .logoicon {
    transform: scale(1) rotate(0deg);
    opacity: 1;
  }
  .logoicon:hover {
    transform: scale(1.12) rotate(0deg) !important;
    opacity: 1;
  }

  /* --- 9. Tag badge entrance + trophy icon bounce --- */
  .tag {
    animation: tag-fade 0.8s ease forwards;
  }
  .tag svg {
    transition: transform 0.3s ease;
    animation: trophy-glow 2s ease-in-out infinite;
  }
  @keyframes tag-fade {
    0% { opacity: 0; transform: translateY(-10px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  @keyframes trophy-glow {
    0%, 100% { transform: scale(1) rotate(0deg); filter: none; }
    25% { transform: scale(1.15) rotate(-5deg); filter: drop-shadow(0 0 4px rgba(37, 99, 235, 0.4)); }
    75% { transform: scale(1.15) rotate(5deg); filter: drop-shadow(0 0 4px rgba(37, 99, 235, 0.4)); }
