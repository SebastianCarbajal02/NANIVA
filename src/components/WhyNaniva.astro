---
import banerImg from '../assets/image/home/why-naniva/baner1-02-02.webp';
---
<section id="por-que-naniva" class="why-naniva">
  <div class="container">
    <img src={banerImg.src} alt="¿Por qué elegir Naniva? Una plataforma diseñada para que tu empresa sea más eficiente, segura y rentable." class="why-naniva-img reveal hover-lift" />
  </div>
</section>

<style>
  .why-naniva {
    padding: 3rem 0;
    background: #f8fafc;
  }
  .why-naniva .container {
    max-width: 1870px;
  }
  .why-naniva-img {
    display: block;
    width: 99%;
    height: auto;
    margin-left: auto;
    border-radius: var(--radius);
    box-shadow: 0 0 20px rgba(37, 99, 235, 0.35), 0 0 45px rgba(37, 99, 235, 0.2);
    transition: box-shadow 0.3s ease;
  }
  .why-naniva-img:hover {
    transform: scale(1.015);
    box-shadow: 0 0 25px rgba(37, 99, 235, 0.7), 0 0 60px rgba(37, 99, 235, 0.5);
  }
</style>
