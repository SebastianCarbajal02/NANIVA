---
import brandLogo from '../assets/image/shared/logos/logo-inicio.webp';
import complianceImg1 from '../assets/image/home/footer/iconsunatd-05.webp';
import complianceImg2 from '../assets/image/home/footer/iconsunatd-06.webp';

const year = new Date().getFullYear();

function iconSvg(name: string, color: string = "#2563eb", size = 20) {
  const icons: Record<string, string> = {
    chevron: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>`,
    mail: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 6-10 7L2 6"/></svg>`,
    phone: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>`,
    whatsapp: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="${color}"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.9-7.01A9.86 9.86 0 0 0 12.04 2m0 1.67a8.2 8.2 0 0 1 5.83 2.42 8.19 8.19 0 0 1 2.41 5.82c0 4.55-3.7 8.25-8.25 8.25a8.25 8.25 0 0 1-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.39c0-4.55 3.7-8.24 8.26-8.24m-4.53 4.7c-.16 0-.42.06-.64.3-.22.24-.85.83-.85 2.03 0 1.2.87 2.35.99 2.51.12.16 1.7 2.7 4.19 3.7 2.07.82 2.49.66 2.94.62.45-.04 1.45-.6 1.65-1.17.2-.58.2-1.08.14-1.18-.06-.1-.22-.16-.46-.28-.24-.12-1.45-.72-1.67-.8-.22-.08-.39-.12-.55.12-.16.24-.63.8-.78.97-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.34-.76-1.83-.2-.48-.4-.42-.55-.42h-.47z"/></svg>`,
    calendar: `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>`,
    book: `<svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2Z"/></svg>`,
    tiktok: `<svg viewBox="0 0 24 24" width="16" height="16" fill="#2563eb"><path d="M16.6 5.82c-.7-.77-1.09-1.77-1.09-2.82h-3.09v13.44a2.6 2.6 0 0 1-4.59 1.66 2.6 2.6 0 0 1 2.03-4.22c.28 0 .55.04.8.13V10.9a5.7 5.7 0 0 0-.8-.06 5.7 5.7 0 1 0 5.7 5.7V9.4a8.9 8.9 0 0 0 5.2 1.66V8.03a5.3 5.3 0 0 1-4.16-2.21"/></svg>`,
    facebook: `<svg viewBox="0 0 24 24" width="16" height="16" fill="#2563eb"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.1 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.78l-.44 2.89h-2.34v6.99A10 10 0 0 0 22 12"/></svg>`,
    instagram: `<svg viewBox="0 0 24 24" width="16" height="16" fill="#2563eb"><path d="M12 2c2.72 0 3.06.01 4.12.06 1.06.05 1.79.22 2.43.47.66.26 1.21.6 1.76 1.15.55.55.89 1.1 1.15 1.76.25.64.42 1.37.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.06-.22 1.79-.47 2.43a4.9 4.9 0 0 1-1.15 1.76 4.9 4.9 0 0 1-1.76 1.15c-.64.25-1.37.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.06-.05-1.79-.22-2.43-.47a4.9 4.9 0 0 1-1.76-1.15 4.9 4.9 0 0 1-1.15-1.76c-.25-.64-.42-1.37-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.06.22-1.79.47-2.43.26-.66.6-1.21 1.15-1.76a4.9 4.9 0 0 1 1.76-1.15c.64-.25 1.37-.42 2.43-.47C8.94 2.01 9.28 2 12 2m0 1.8c-2.67 0-2.99.01-4.04.06-.87.04-1.34.18-1.65.3-.42.16-.71.36-1.02.67-.31.31-.51.6-.67 1.02-.12.31-.26.78-.3 1.65-.05 1.05-.06 1.37-.06 4.04s.01 2.99.06 4.04c.04.87.18 1.34.3 1.65.16.42.36.71.67 1.02.31.31.6.51 1.02.67.31.12.78.26 1.65.3 1.05.05 1.37.06 4.04.06s2.99-.01 4.04-.06c.87-.04 1.34-.18 1.65-.3.42-.16.71-.36 1.02-.67.31-.31.51-.6.67-1.02.12-.31.26-.78.3-1.65.05-1.05.06-1.37.06-4.04s-.01-2.99-.06-4.04c-.04-.87-.18-1.34-.3-1.65a2.7 2.7 0 0 0-.67-1.02 2.7 2.7 0 0 0-1.02-.67c-.31-.12-.78-.26-1.65-.3-1.05-.05-1.37-.06-4.04-.06M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 1.8a3.2 3.2 0 1 0 0 6.4 3.2 3.2 0 0 0 0-6.4m5.2-2a1.17 1.17 0 1 1-2.33 0 1.17 1.17 0 0 1 2.33 0"/></svg>`,
    youtube: `<svg viewBox="0 0 24 24" width="16" height="16" fill="#2563eb"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.6 12 3.6 12 3.6s-7.6 0-9.4.5A3 3 0 0 0 .5 6.2 31 31 0 0 0 0 12a31 31 0 0 0 .5 5.8 3 3 0 0 0 2.1 2.1c1.8.5 9.4.5 9.4.5s7.6 0 9.4-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 24 12a31 31 0 0 0-.5-5.8M9.6 15.6V8.4l6.3 3.6z"/></svg>`,
  };
  return icons[name] ?? "";
}

const productLinks = ["ERP", "Ecommerce", "Facturación electrónica", "Catálogo digital", "Inteligencia Artificial", "Integraciones"];
const resourceLinks = ["Casos de éxito", "Blog", "Centro de ayuda", "Documentación API", "Precios"];
const companyLinks = ["Nosotros", "Clientes", "Trabaja con nosotros", "Contacto"];

const socials = [
  { icon: "tiktok", href: "https://www.tiktok.com/@naniva_tec_sac", label: "TikTok" },
  { icon: "facebook", href: "https://www.facebook.com/valeapp.sistemadefacturacion", label: "Facebook" },
  { icon: "instagram", href: "#", label: "Instagram" },
  { icon: "youtube", href: "https://www.youtube.com/@NanivaTechnologies", label: "YouTube" },
];

const complianceBadges = [
  { img: complianceImg1, alt: "Facturación Electrónica - Autorizados por SUNAT" },
  { img: complianceImg2, alt: "Contribuyente Autorizado - Autorizados por SUNAT" },
];
---
<footer>
  <div class="container">
    <div class="top-grid">
      <div class="brand">
        <div class="brand-row">
          <img src={brandLogo.src} alt="Naniva" class="brand-logo" />
          <strong>Naniva</strong>
        </div>
        <p>La plataforma inteligente<br />para hacer crecer<br />tu empresa.</p>
        <div class="socials">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.label} class="social" set:html={iconSvg(s.icon)} />
          ))}
        </div>
      </div>

      <div class="links-col">
        <h4>Producto</h4>
        {productLinks.map((link) => (
          <a href="#" set:html={`${iconSvg('chevron', '#2563eb')} <span>${link}</span>`} />
        ))}
      </div>

      <div class="links-col">
        <h4>Recursos</h4>
        {resourceLinks.map((link) => (
          <a href="#" set:html={`${iconSvg('chevron', '#2563eb')} <span>${link}</span>`} />
        ))}
        <a href="#" set:html={`${iconSvg('book', '#2563eb')} <span>Libro de Reclamaciones</span>`} />
      </div>

      <div class="links-col">
        <h4>Empresa</h4>
        {companyLinks.map((link) => (
          <a href="#" set:html={`${iconSvg('chevron', '#2563eb')} <span>${link}</span>`} />
        ))}
      </div>

      <div class="contact-col">
        <h4>¿Hablemos de tu proyecto?</h4>
        <p>Agenda una demostración personalizada.</p>
        <div class="contact-list">
          <a href="mailto:hola@naniva.com" set:html={`${iconSvg('mail')} hola@naniva.com`} />
          <a href="tel:+51987654321" set:html={`${iconSvg('phone')} +51 987 654 321`} />
          <a href="https://wa.me/51987654321" target="_blank" rel="noopener noreferrer" set:html={`${iconSvg('whatsapp', '#25D366')} Escríbenos por WhatsApp`} />
        </div>
        <a href="#demo" class="cta-btn hover-pop" set:html={`${iconSvg('calendar')} Solicitar demostración →`} />
      </div>
    </div>

    <div class="compliance-divider"><span>Naniva cumple con los estándares que tu empresa necesita</span></div>

    <div class="compliance-bar">
      {complianceBadges.map((b) => (
        <img src={b.img.src} alt={b.alt} class="compliance-img" />
      ))}
    </div>
  </div>

  <div class="bottom">
    <div class="container bottom-inner">
      <p>&copy; {year} Naniva. Todos los derechos reservados.</p>
      <div class="bottom-links">
        <a href="#">Términos y condiciones</a>
        <span class="sep">|</span>
        <a href="#">Política de privacidad</a>
        <span class="sep">|</span>
        <a href="#">Política de cookies</a>
      </div>
      <span class="lang">Español ⌄</span>
    </div>
  </div>
</footer>

<style>
footer {
  background: #f8fafc;
  color: #475569;
  border-top: 1px solid #e2e8f0;
  box-shadow: 0 -14px 40px rgba(15, 23, 42, 0.06);
  position: relative;
}
footer .container {
  width: 100%;
  max-width: 1600px;
  margin: 0 auto;
  padding: 3rem 1.5rem 0;
}
.top-grid {
  display: grid;
  grid-template-columns: 1.3fr 1fr 1fr 1fr 1.3fr;
  gap: 2rem;
  margin-bottom: 2rem;
}
.brand-row {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  margin-bottom: 1rem;
}
.brand-logo {
  width: 100px;
  height: 100px;
  object-fit: contain;
  flex-shrink: 0;
 transform: translateY(-2rem);
}
.brand strong {
  font-size: 2.5rem;
  color: #0f172a;
  transform: translateY(-2rem);
}
.brand p {
  font-size: 1rem;
  line-height: 1.5;
  margin-bottom: 1.25rem;
  color: #64748b;
  font-weight: 700;
  transform: translateY(-2rem);
}
.socials {
  display: flex;
  gap: 0.6rem;
  
}
.social {
  width: 55px;
  height: 55px;
  border-radius: 999px;
  background: #eaf1ff;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s ease, transform 0.2s ease;
  
  
}
.social:hover {
  background: #dbeafe;
  transform: translateY(-2px);
}
.links-col h4 {
  font-size: 1rem;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 1rem;
}
.links-col a {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  color: #475569;
  text-decoration: none;
  font-size: 0.9rem;
  margin-bottom: 0.75rem;
  transition: color 0.2s ease;
}
.links-col a:hover { color: #2563eb; }
.contact-col h4 {
  font-size: 1.05rem;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 0.4rem;
  line-height: 1.3;
}
.contact-col > p {
  font-size: 0.85rem;
  color: #64748b;
  margin-bottom: 1rem;
}
.contact-list {
  display: flex;
  flex-direction: column;
  gap: 0.7rem;
  margin-bottom: 1.25rem;
}
.contact-list a {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: #334155;
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 600;
}
.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: #2563eb;
  color: white;
  padding: 0.85rem 1.5rem;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.9rem;
  width: fit-content;
}
.compliance-divider {
  display: flex;
  align-items: center;
  gap: 1rem;
  text-align: center;
  justify-content: center;
  margin-bottom: 1.5rem;
}
.compliance-divider::before,
.compliance-divider::after {
  content: "";
  flex: 1;
  height: 1px;
  background: #e2e8f0;
}
.compliance-divider span {
  white-space: nowrap;
  font-size: 0.85rem;
  font-weight: 700;
  color: #64748b;
}
.compliance-bar {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.25rem;
  max-width: 900px;
  margin: 0 auto 2rem;
}
.compliance-img {
  width: 100%;
  height: auto;
  border-radius: 12px;
  display: block;
}
.bottom {
  background: linear-gradient(135deg, #0b1220, #16233d);
  color: rgba(255, 255, 255, 0.7);
  padding: 1.25rem 0;
}
.bottom-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
  padding: 0 1.5rem;
  font-size: 0.85rem;
}
.bottom-links {
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.bottom-links a {
  color: rgba(255, 255, 255, 0.7);
  text-decoration: none;
}
.bottom-links a:hover { color: white; }
.sep { opacity: 0.4; }
.lang { color: rgba(255, 255, 255, 0.7); }

@media (max-width: 1200px) {
  .top-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 700px) {
  .top-grid { grid-template-columns: 1fr; }
  .compliance-bar { grid-template-columns: 1fr; }
  .bottom-inner { flex-direction: column; text-align: center; }
}
</style>
