---
import dashboardImg from '../assets/image/Dashboard.webp';
import dashboardZoom1Img from '../assets/image/img-zoom-1.png';
import dashboardZoom2Img from '../assets/image/img-zoom-2.png';
import dashboardZoom3Img from '../assets/image/img-zoom-3.png';
const bullets = [
  "Dashboard intuitivo",
  "Módulos integrados",
  "Información actualizada",
  "Fácil de usar",
];
---
<section class="showcase">
  <div class="container">
    <div class="panel reveal">
      <button type="button" class="mockup" id="dashboard-zoom-trigger" aria-label="Ampliar imagen del dashboard">
        <img src={dashboardImg.src} alt="Dashboard NANIVA" class="img-default" />
        <img src={dashboardZoom1Img.src} alt="Dashboard NANIVA detalle" class="img-zoom-1" />
        <img src={dashboardZoom2Img.src} alt="Dashboard NANIVA detalle 2" class="img-zoom-2" />
        <img src={dashboardZoom3Img.src} alt="Dashboard NANIVA detalle 3" class="img-zoom-3" />
      </button>
      <div class="info">
        <h2>Todo tu negocio<br />bajo control</h2>
        <p>Visualiza tus ventas, productos, clientes y más en un solo lugar. Información clara para tomar mejores decisiones.</p>
        <ul>
          {bullets.map((b) => (
            <li><span class="check">✓</span>{b}</li>
          ))}
        </ul>
        <a href="#demo" class="cta hover-pop">▶ Ver Demo del Sistema →</a>
      </div>
    </div>
  </div>
</section>

<script>
  const trigger = document.getElementById('dashboard-zoom-trigger');
  trigger?.addEventListener('click', () => {
    trigger.classList.toggle('zoomed');
  });

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (trigger && !reduceMotion) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => trigger.classList.add('reveal-zoom'), 300);
          setTimeout(() => trigger.classList.remove('reveal-zoom'), 2500);
          setTimeout(() => trigger.classList.add('reveal-zoom-2'), 3600);
          setTimeout(() => trigger.classList.remove('reveal-zoom-2'), 5800);
          setTimeout(() => trigger.classList.add('reveal-zoom-3'), 6900);
          setTimeout(() => trigger.classList.remove('reveal-zoom-3'), 9100);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });
    io.observe(trigger);
  }
</script>

<style>
  .showcase { background: white; padding-top: 1.5rem; }
  .showcase .container { max-width: 1500px; }
  .panel {
    display: flex;
    align-items: center;
    gap: 2rem;
    background: linear-gradient(135deg, #eef4ff, #f5f8ff);
    border-radius: 20px;
    padding: 1.5rem;
    flex-wrap: wrap;
  }
  .mockup {
    position: relative;
    flex: 3.4;
    min-width: 760px;
    aspect-ratio: 2917 / 1334;
    border-radius: 14px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.1);
    overflow: hidden;
    border: none;
    padding: 0;
    transition: box-shadow 0.25s ease;
  }
  .mockup:hover {
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.16);
  }
  .mockup.zoomed {
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.28);
  }
  .mockup img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .img-default,
  .img-zoom,
  .img-zoom-1,
  .img-zoom-2,
  .img-zoom-3 {
    position: absolute;
    opacity: 1;
    transition: opacity 0.35s ease, transform 0.35s ease, filter 0.8s ease;
  }
  .img-default {
    animation: float 4s ease-in-out infinite;
  }
  .img-zoom {
    opacity: 0;
    transform: scale(1.08);
  }
  .mockup.zoomed .img-default {
    opacity: 0;
  }
  .mockup.zoomed .img-zoom {
    opacity: 1;
    transform: scale(1);
  }
  .img-zoom-1 {
    opacity: 0;
    transform-origin: top left;
    transform: scale(0.15) translate(-40%, -60%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .img-zoom-2 {
    opacity: 0;
    transform-origin: top left;
    transform: scale(0.15) translate(20%, -20%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .img-zoom-3 {
    opacity: 0;
    transform-origin: bottom right;
    transform: scale(0.15) translate(30%, 60%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .mockup.reveal-zoom .img-default,
  .mockup.reveal-zoom-2 .img-default,
  .mockup.reveal-zoom-3 .img-default {
    filter: blur(6px);
  }
  .mockup.reveal-zoom .img-zoom-1 {
    opacity: 1;
    transform: scale(0.6) translate(0, 0);
  }
  .mockup.reveal-zoom-2 .img-zoom-2 {
    opacity: 1;
    transform: scale(0.6) translate(12%, 12%);
  }
  .mockup.reveal-zoom-3 .img-zoom-3 {
    opacity: 1;
    transform: scale(0.6) translate(0, 0);
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-14px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mockup { transition: none; }
    .mockup img { animation: none; }
  }
  .info { flex: 1; min-width: 320px; }
  .info h2 {
    font-size: clamp(1rem, 3.6vw, 2rem);
    line-height: 1.2;
    margin-bottom: 1.25rem;
    color: #0f172a;
  }
  .info p {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }
  .info ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2.25rem;
  }
  .info li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-weight: 600;
    font-size: 1.05rem;
    color: #1e293b;
  }
  .check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 999px;
    background: #2563eb;
    color: white;
    font-size: 0.8rem;
    flex-shrink: 0;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    background: #2563eb;
    color: white;
    padding: 1rem 2rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1.1rem;
  }
  @media (max-width: 900px) {
    .mockup { min-width: 100%; flex-basis: 100%; }
  }
  @media (max-width: 600px) {
    .panel { padding: 1rem; gap: 1.25rem; }
    .info h2 { font-size: 1.5rem; }
    .info p { font-size: 0.95rem; }
    .info li { font-size: 0.9rem; }
    .cta { width: 100%; justify-content: center; font-size: 0.95rem; padding: 0.85rem 1.5rem; }
  }
</style>
