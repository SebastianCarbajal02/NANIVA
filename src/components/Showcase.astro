---
import dashboardImg from '../assets/image/dashfin1_Mesa de trabajo 1.webp';
import dashboardZoom1Img from '../assets/image/dashboardff1-01.webp';
import dashboardZoom2Img from '../assets/image/dashboardff1-02.webp';
import dashboardZoom3Img from '../assets/image/dashboardff1-03.webp';
import dashboardZoom4Img from '../assets/image/dashboardff1-04.webp';
import iconVentas from '../assets/image/iconsdashb1-22.webp';
import iconRecomendaciones from '../assets/image/iconsdashb1-23.webp';
import iconConectada from '../assets/image/iconsdashb1-24.webp';
import iconInformacion from '../assets/image/iconsdashb1-25.webp';

const features = [
  { icon: iconVentas, title: "Ventas e indicadores", sub: "en tiempo real" },
  { icon: iconRecomendaciones, title: "Recomendaciones", sub: "impulsadas por IA" },
  { icon: iconConectada, title: "Toda tu empresa", sub: "conectada" },
  { icon: iconInformacion, title: "Información clara", sub: "para decidir mejor" },
];
---
<section class="showcase">
  <div class="container">
    <div class="section-header">
      <span class="eyebrow">CONOCE NANIVA EN ACCIÓN</span>
      <h1>Explora nuestro <span class="brand">Dashboard</span></h1>
      <p class="section-sub">Descubre cómo Naniva puede transformar la gestión de tu empresa.</p>
    </div>
    <div class="panel reveal">
      <button type="button" class="mockup" id="dashboard-zoom-trigger" aria-label="Ampliar imagen del dashboard">
        <img src={dashboardImg.src} alt="Dashboard NANIVA" class="img-default" />
        <img src={dashboardZoom1Img.src} alt="Dashboard NANIVA detalle" class="img-zoom-1" />
        <img src={dashboardZoom3Img.src} alt="Dashboard NANIVA detalle 3" class="img-zoom-2" />
        <img src={dashboardZoom4Img.src} alt="Dashboard NANIVA detalle 4" class="img-zoom-3" />
        <img src={dashboardZoom2Img.src} alt="Dashboard NANIVA detalle 2" class="img-zoom-4" />
      </button>
      <div class="info">
        <span class="badge">• DASHBOARD INTELIGENTE</span>
        <h2>El centro de control<br />de <span class="brand">tu empresa</span></h2>
        <p>Toda la información que necesitas, en tiempo real. Toma decisiones inteligentes y lleva tu negocio al siguiente nivel.</p>
        <ul>
          {features.map((f) => (
            <li>
              <span class="feature-icon-wrap"><img src={f.icon.src} alt="" class="feature-icon" /></span>
              <span class="feature-text">{f.title} {f.sub}</span>
            </li>
          ))}
        </ul>
        <a href="#demo" class="cta hover-pop">Explorar Dashboard →</a>
      </div>
    </div>
  </div>
</section>

<script>
  const trigger = document.getElementById('dashboard-zoom-trigger');

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (trigger && !reduceMotion) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setTimeout(() => trigger.classList.add('reveal-zoom'), 300);
          setTimeout(() => trigger.classList.remove('reveal-zoom'), 2500);
          setTimeout(() => trigger.classList.add('reveal-zoom-2'), 3600);
          setTimeout(() => trigger.classList.remove('reveal-zoom-2'), 5800);
          setTimeout(() => trigger.classList.add('reveal-zoom-3'), 6900);
          setTimeout(() => trigger.classList.remove('reveal-zoom-3'), 9100);
          setTimeout(() => trigger.classList.add('reveal-zoom-4'), 10200);
          setTimeout(() => trigger.classList.remove('reveal-zoom-4'), 12400);
          io.unobserve(entry.target);
        }
      });
    }, { threshold: 0.4 });
    io.observe(trigger);
  }
</script>

<style>
  .showcase { background: white; padding-top: 3rem; }
  .showcase .container { max-width: 1680px; }
  .section-header {
    text-align: center;
    margin-top: 5rem;
    margin-bottom: 1rem;
     transform: translateY(-4rem);
  }
  .eyebrow {
    display: inline-block;
    color: #2563eb;
    font-weight: 750;
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    margin-bottom: 0.5rem;
  }
  .showcase h1 {
    font-size: clamp(1.8rem, 4vw, 3.6rem);
    font-weight: 800;
    color: #0f172a;
    margin-bottom: 0.75rem;
  }
  .section-sub {
    color: var(--color-text-muted);
    font-size: 1.5rem;
    font-weight: 650;
  }
  .panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 5rem;
    flex-wrap: wrap;
    transform: translateY(-4rem);
  }
  .mockup {
    position: relative;
    flex: 3.6;
    min-width: 640px;
    aspect-ratio: 2157 / 1305;
    border-radius: 14px;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 14px 40px rgba(15, 23, 42, 0.1);
    overflow: visible;
    border: none;
    padding: 0;
    transition: box-shadow 0.25s ease;
  }
  .mockup:hover {
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.16);
  }
  .mockup img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .img-default,
  .img-zoom,
  .img-zoom-1,
  .img-zoom-2,
  .img-zoom-3,
  .img-zoom-4 {
    position: absolute;
    opacity: 1;
    transition: opacity 0.35s ease, transform 0.35s ease, filter 0.8s ease;
  }
  .mockup img.img-default {
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    transform: translate(-50%, -50%);
  }
  .img-zoom {
    opacity: 0;
    transform: scale(1.08);
  }
  .img-zoom-1 {
    opacity: 0;
    transform-origin: top left;
    transform: scale(0.15) translate(-05%, -05%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .img-zoom-2 {
    opacity: 0;
    transform-origin: top left;
    transform: scale(0.15) translate(-05%, -05%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .img-zoom-3 {
    opacity: 0;
    transform-origin: bottom right;
    transform: scale(0.13) translate(30%, 10%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .img-zoom-4 {
    opacity: 0;
    transform-origin: bottom right;
    transform: scale(0.13) translate(20%, -5%);
    z-index: 2;
    transition: opacity 1.1s ease, transform 1.1s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .mockup.reveal-zoom .img-default,
  .mockup.reveal-zoom-2 .img-default,
  .mockup.reveal-zoom-3 .img-default,
  .mockup.reveal-zoom-4 .img-default {
    filter: blur(6px);
  }
  .mockup.reveal-zoom .img-zoom-1 {
    opacity: 1;
    transform: scale(0.6) translate(18%, 18%);
  }
  .mockup.reveal-zoom-2 .img-zoom-2 {
    opacity: 1;
    transform: scale(0.6) translate(28%, 28%);
  }
  .mockup.reveal-zoom-3 .img-zoom-3 {
    opacity: 1;
    transform: scale(0.6) translate(-18%, -18%);
  }
  .mockup.reveal-zoom-4 .img-zoom-4 {
    opacity: 1;
    transform: scale(0.6) translate(-25%, -35%);
  }
  @media (prefers-reduced-motion: reduce) {
    .mockup { transition: none; }
    .mockup img { animation: none; }
  }
  .info {
    flex: 0.8;
    min-width: 320px;
    background: linear-gradient(160deg, #0b1220, #16233d);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    background: rgba(37, 99, 235, 0.18);
    color: #60a5fa;
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    padding: 0.40rem 0.8rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }
  .info h2 {
    font-size: clamp(1rem, 3.6vw, 1.5rem);
    line-height: 1.2;
    margin-bottom: 1.25rem;
    color: white;
  }
  .brand { color: #60a5fa; }
  .info p {
    font-size: 1rem;
    line-height: 1.5;
    color: #94a3b8;
    margin-bottom: 1.5rem;
  }
  .info ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    margin-bottom: 1.75rem;
  }
  .info li {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.9rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  .info li:last-child { border-bottom: none; }
  .feature-icon-wrap {
    width: 65px;
    height: 65px;
    flex-shrink: 0;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease, background 0.25s ease, box-shadow 0.25s ease;
  }
  .info li:hover .feature-icon-wrap {
    transform: scale(1.12);
    background: radial-gradient(circle, rgba(255, 255, 255, 0.4), rgba(255, 255, 255, 0.05));
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.6);
  }
  .feature-icon {
    width: 65px;
    height: 65px;
    object-fit: contain;
    transition: transform 0.25s ease;
  }
  .info li:hover .feature-icon {
    transform: scale(1.08);
  }
  .feature-text {
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1.3;
    color: white;
  }
  .cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    width: 100%;
    background: #2563eb;
    color: white;
    padding: 1rem 2rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 1rem;
  }
  @media (max-width: 900px) {
    .mockup { min-width: 100%; flex-basis: 100%; }
  }
  @media (max-width: 600px) {
    .panel { gap: 1.25rem; }
    .info h2 { font-size: 1.5rem; }
    .info p { font-size: 0.95rem; }
    .feature-text { font-size: 0.9rem; }
    .cta { width: 100%; justify-content: center; font-size: 0.95rem; padding: 0.85rem 1.5rem; }
  }
</style>
