---
import banner from '../assets/image/fondo final1-01.png';
import heroPeople from '../assets/image/hompersonas fin1-02.png';
import heroDashboard from '../assets/image/dashboardfinalp1-03.png';
import logo from '../assets/image/logo.webp';
import iconPos from '../assets/image/icono-iniicio-punto_venta.png';
import iconEcommerce from '../assets/image/icono-inicio-ecomerce.png';
import iconReportes from '../assets/image/iconos-inicio-reporte.png';
import iconFacturacion from '../assets/image/facturacion-eletronica.png';
import iconEmpresarial from '../assets/image/icono-empresarial.png';
import iconErp from '../assets/image/icono-erp.png';
import iconSunat from '../assets/image/sunat-Photoroom.webp';
import iconVisa from '../assets/image/Visa-Logo.webp';
import iconMastercard from '../assets/image/mastecard.webp';
import iconYape from '../assets/image/YAPE.webp';

const features = [
  { icon: iconPos, label: "Punto de Venta (POS)" },
  { icon: iconEcommerce, label: "Ecommerce" },
  { icon: iconReportes, label: "Reportes Inteligentes" },
  { icon: iconFacturacion, label: "Facturación Electrónica" },
  { icon: iconEmpresarial, label: "IA Empresarial" },
  { icon: iconErp, label: "ERP" },
];

const partners = [
  { label: "SUNAT", icon: iconSunat },
  { label: "Yape", icon: iconYape },
  { label: "VISA", icon: iconVisa },
  { label: "Mastercard", icon: iconMastercard },
  { label: "WhatsApp", isWhatsapp: true },
];
---
<section class="hero" style={`background-image: url('${banner.src}');`}>
  <div class="content reveal">
    <span class="tag">PLATAFORMA TODO EN UNO</span>
    <h1>La plataforma<br /><span class="highlight">inteligente</span><br />para hacer crecer<br />tu empresa.</h1>
    <p>Administra ventas, inventario, facturación electrónica,<br />ecommerce e inteligencia artificial <span class="p-highlight">desde una sola plataforma</span>.</p>
    <div class="hero-actions">
      <a href="#demo" class="btn-primary hover-pop">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
        Solicitar demostración
      </a>
      <a href="#demo" class="btn-outline hover-pop">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="m10 8 6 4-6 4V8Z" fill="currentColor" stroke="none" /></svg>
        Ver cómo funciona
      </a>
    </div>
    <div class="features">
      {features.map((f) => (
        <div class="feature">
          <span class="feature-icon"><img src={f.icon.src} alt={f.label} /></span>
        </div>
      ))}
    </div>
  </div>

  <div class="hero-visual reveal">
    <img src={heroDashboard.src} alt="Dashboard Naniva" class="hero-dashboard" />
    <img src={heroPeople.src} alt="" class="hero-people" />
  </div>
</section>

<style>
  /* ===== CONTENEDOR PRINCIPAL ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    padding: 2rem clamp(1rem, 3vw, 5rem);
    overflow: hidden;
    gap: 2rem;
  }

  /* ===== CONTENIDO TEXTO ===== */
  .content {
    max-width: min(580px, 50%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.5rem;
    margin-right: auto;
    position: relative;
    z-index: 3;
  }

  .logo {
    height: clamp(56px, 7vw, 92px);
    width: auto;
    object-fit: contain;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.25);
    color: #2563eb;
    font-weight: 700;
    font-size: clamp(0.65rem, 0.8vw, 0.75rem);
    letter-spacing: 0.08em;
    padding: 0.2rem 0.8rem;
    border-radius: 999px;
  }

  h1 {
    font-size: clamp(2rem, 3.5vw, 3.2rem);
    font-weight: 798;
    line-height: 1.15;
    color: #0f172a;
  }
  .highlight { color: #2563eb; }

  p {
    font-size: clamp(0.9rem, 1.2vw, 1.1rem);
    font-weight: 500;
    color: #475569;
    line-height: 1.6;
    max-width: 560px;
  }
  .p-highlight { color: #2563eb; font-weight: 800; }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: white;
    font-weight: 600;
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: #0f172a;
    font-weight: 600;
    font-size: clamp(0.85rem, 1vw, 0.95rem);
    padding: 0.7rem 1.4rem;
    border: 1.5px solid #2563eb;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }

  /* ===== FEATURES ICONS ===== */
  .features {
    display: flex;
    gap: clamp(0.8rem, 1.5vw, 1.5rem);
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    width: clamp(60px, 6vw, 80px);
    text-align: center;
  }

  .feature-icon {
    width: clamp(56px, 6vw, 80px);
    height: clamp(56px, 6vw, 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid transparent;
    border-radius: 16px;
    transition: transform 0.25s ease, border-color 0.25s ease, filter 0.25s ease;
  }
  .feature:hover .feature-icon {
    transform: translateY(-5px) scale(1.12);
    border-color: #2563eb;
    filter: brightness(1.35);
  }
  .feature-icon img {
    width: clamp(80px, 8vw, 115px);
    height: clamp(80px, 8vw, 115px);
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .feature-label {
    font-size: 0.7rem;
    font-weight: 600;
    color: #334155;
  }

  /* ===== PARTNERS ===== */
  .partners {
    margin-top: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    background: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 1rem;
    border-radius: 15px;
    font-size: 0.85rem;
    width: max-content;
    max-width: 100%;
  }
  .partners-label { font-weight: 600; color: #64748b; white-space: nowrap; }
  .partner { color: #334155; font-weight: 600; white-space: nowrap; }
  .partner-icon { height: clamp(28px, 3vw, 34px); width: auto; object-fit: contain; }
  .partner-icon-lg { height: clamp(44px, 5vw, 64px); }

  /* ===== VISUAL (dashboard + people) ===== */
  .hero-visual {
    position: absolute;
    right: 0;
    bottom: 0;
    width: min(52%, 820px);
    height: 90%;
    pointer-events: none;
    z-index: 2;
  }

  .hero-people {
    position: absolute;
    left: -30%;
    bottom: 0;
    width: 130%;
    height: auto;
    object-fit: contain;
    z-index: 2;
    transition: filter 0.3s ease;
  }
  .hero-people:hover {
    filter: drop-shadow(0 0 20px rgba(37, 99, 235, 0.7)) drop-shadow(0 0 45px rgba(37, 99, 235, 0.5));
  }

  .hero-dashboard {
    position: absolute;
    top: 5%;
    right: 5%;
    width: 90%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(15, 23, 42, 0.25));
    z-index: 1;
    transition: transform 0.3s ease;
    pointer-events: auto;
  }
  .hero-dashboard:hover {
    transform: scale(1.06);
  }

  /* ===== RESPONSIVE ===== */

  /* Pantallas grandes (>= 1500px) — centrar contenido */
  @media (min-width: 1500px) {
    .hero {
      justify-content: center;
    }
    .content {
      max-width: 580px;
    }
  }

  /* Tablets landscape / laptops pequeñas (1100px - 1499px) */
  @media (max-width: 1300px) {
    .hero-visual {
      width: 48%;
      height: 80%;
    }
    .hero-dashboard {
      top: 10%;
      width: 85%;
    }
    .hero-people {
      left: -25%;
      width: 120%;
    }
  }

  @media (max-width: 1100px) {
    .hero-visual {
      width: 44%;
      height: 70%;
      right: -2%;
    }
    .hero-dashboard {
      top: 12%;
      width: 80%;
    }
    .hero-people {
      left: -20%;
      width: 110%;
    }
  }

  /* Tablets portrait (768px - 1099px) */
  @media (max-width: 900px) {
    .hero {
      padding: 3rem 1.5rem;
      min-height: auto;
      gap: 1.5rem;
    }
    .content {
      max-width: 55%;
    }
    .hero-visual {
      width: 42%;
      height: auto;
      position: absolute;
      right: 0;
      bottom: 0;
    }
    .hero-dashboard {
      position: relative;
      top: auto;
      right: auto;
      width: 100%;
    }
    .hero-people {
      display: none;
    }
    h1 { font-size: clamp(1.8rem, 4.5vw, 2.5rem); }
    .features { gap: 0.8rem; }
  }

  /* Móviles grandes / tablets pequeñas (600px - 767px) */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column;
      background-position: 65% center;
      padding: 2rem 1rem;
      min-height: auto;
    }
    .content {
      max-width: 100%;
      background: rgba(255, 255, 255, 0.92);
      backdrop-filter: blur(10px);
      padding: 1.5rem;
      border-radius: var(--radius);
      width: 100%;
    }
    .hero-visual {
      display: none;
    }
    .logo { height: 64px; }
    h1 { font-size: clamp(1.6rem, 6vw, 2rem); }
    p { font-size: 0.95rem; }
    .features {
      justify-content: center;
      gap: 0.6rem;
    }
    .feature { width: 56px; }
    .feature-icon { width: 48px; height: 48px; }
    .feature-icon img { width: 56px; height: 56px; }
    .partners { width: 100%; justify-content: center; }
    .hero-actions { justify-content: center; }
  }

  /* Móviles pequeños (< 600px) */
  @media (max-width: 600px) {
    .hero {
      padding: 1.5rem 0.75rem;
    }
    .content {
      padding: 1rem;
    }
    h1 { font-size: clamp(1.4rem, 7vw, 1.7rem); }
    .feature { width: 48px; }
    .feature-icon { width: 40px; height: 40px; }
    .feature-icon img { width: 48px; height: 48px; }
    .hero-actions {
      flex-direction: column;
      width: 100%;
    }
    .btn-primary, .btn-outline {
      width: 100%;
      justify-content: center;
      font-size: 0.85rem;
    }
  }

  @media (max-width: 400px) {
    .features { gap: 0.4rem; }
    .feature { width: 44px; }
    .feature-icon { width: 36px; height: 36px; }
    .feature-icon img { width: 42px; height: 42px; }
    h1 { font-size: clamp(1.2rem, 6vw, 1.4rem); }
  }
</style>