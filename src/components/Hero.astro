---
import banner from '../assets/image/banner.webp';
import logo from '../assets/image/logo.webp';
import iconPos from '../assets/image/icono-iniicio-punto_venta.png';
import iconEcommerce from '../assets/image/icono-inicio-ecomerce.png';
import iconReportes from '../assets/image/iconos-inicio-reporte.png';
import iconFacturacion from '../assets/image/facturacion-eletronica.png';
import iconEmpresarial from '../assets/image/icono-empresarial.png';
import iconErp from '../assets/image/icono-erp.png';
import iconSunat from '../assets/image/sunat-Photoroom.webp';
import iconVisa from '../assets/image/Visa-Logo.webp';
import iconMastercard from '../assets/image/mastecard.webp';
import iconYape from '../assets/image/YAPE.webp';

const features = [
  { icon: iconPos, label: "Punto de Venta (POS)" },
  { icon: iconEcommerce, label: "Ecommerce" },
  { icon: iconReportes, label: "Reportes Inteligentes" },
  { icon: iconFacturacion, label: "Facturación Electrónica" },
  { icon: iconEmpresarial, label: "IA Empresarial" },
  { icon: iconErp, label: "ERP" },
];

const partners = [
  { label: "SUNAT", icon: iconSunat },
  { label: "Yape", icon: iconYape },
  { label: "VISA", icon: iconVisa },
  { label: "Mastercard", icon: iconMastercard },
  { label: "WhatsApp", isWhatsapp: true },
];
---
<section class="hero" style={`background-image: url('${banner.src}');`}>
  <div class="content reveal">
    <span class="tag">PLATAFORMA TODO EN UNO</span>
    <h1>La plataforma<br /><span class="highlight">inteligente</span><br />para hacer crecer<br />tu empresa.</h1>
    <p>Administra ventas, inventario, facturación electrónica,<br />ecommerce e inteligencia artificial <span class="p-highlight">desde una sola plataforma</span>.</p>
    <div class="hero-actions">
      <a href="#demo" class="btn-primary hover-pop">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><path d="M16 2v4M8 2v4M3 10h18" /></svg>
        Solicitar demostración
      </a>
      <a href="#demo" class="btn-outline hover-pop">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="m10 8 6 4-6 4V8Z" fill="currentColor" stroke="none" /></svg>
        Ver cómo funciona
      </a>
    </div>
    <div class="features">
      {features.map((f) => (
        <div class="feature">
          <span class="feature-icon"><img src={f.icon.src} alt={f.label} /></span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-size: cover; 
    background-position: center;
    background-repeat: no-repeat;
    padding: 4rem 1.5rem 2rem 5rem;
  }
  .content {
    max-width: 580px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    gap: 0.5rem;
    margin-right: auto;
  }
  .logo {
    height: 92px;
    width: auto;
    object-fit: contain;
    transform: translateY(-4rem);
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(37, 99, 235, 0.08);
    border: 1px solid rgba(37, 99, 235, 0.25);
    color: #2563eb;
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    padding: 0.20rem 0.8rem;
    border-radius: 999px;
    box-shadow: 0 2px 8px rgba(37, 99, 235, 0.08);
    transform: translateY(-3rem);
  }
  .tag::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: #2563eb;
  }
  h1 {
    font-size: clamp(4rem, 3.5vw, 2.5rem);
    font-weight: 798;
    line-height: 1.15;
    color: #0f172a;
     transform: translateY(-2rem);
  }
  .highlight {
    color: #2563eb;
  }
  p {
    font-size: 1rem;
    font-weight: 730;
    color: #475569;
    line-height: 1.85;
    max-width: 560px;
     transform: translateY(-1rem);
  }
  .p-highlight {
    color: #2563eb;
    font-weight: 800;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, #1d4ed8, #2563eb);
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
     transform: translateY(-1rem);
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: #0f172a;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 0.85rem 1.5rem;
    border: 1.5px solid #2563eb;
    border-radius: 999px;
    text-decoration: none;
     transform: translateY(-1rem);
  }
  .features {
    display: flex;
    gap: 1.5rem;
    flex-wrap: nowrap;
    position: relative;
    top: 3rem;
  }
  .feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 80px;
    text-align: center;
  }
  .feature-icon {
    width: 80px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .feature-icon img {
    width: 115px;
    height: 115px;
    object-fit: contain;
    mix-blend-mode: multiply;
    
  }
  .partners {
    margin-top: 1.9rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    background: rgba(255, 255, 255, 0.85);
    padding: 0.5rem 1rem;
    border-radius: 15px;
    font-size: 0.90rem;
    width: max-content;
    max-width: 480px;
    
  }
  .partners-label {
    font-weight: 600;
    color: #64748b;
  }
  .partner {
    color: #334155;
    font-weight: 600;
  }
  .partner-icon {
    height: 34px;
    width: auto;
    object-fit: contain;
  }
  .partner-icon-lg {
    height: 64px;
  }
  @media (max-width: 900px) {
    .hero { padding-left: 1.5rem; }
  }
  @media (max-width: 768px) {
    .hero {
      background-position: 70% center;
      padding: 6.5rem 1rem 2rem;
      min-height: auto;
    }
    .content {
      max-width: 100%;
      background: rgba(255, 255, 255, 0.9);
      padding: 1.5rem;
      border-radius: var(--radius);
    }
    .logo { transform: translateY(-1rem); height: 64px; }
    h1 { transform: none; font-size: clamp(1.8rem, 7vw, 2.25rem); }
    p { font-size: 1.05rem; }
    .features { gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .feature { width: 64px; }
    .feature-icon { width: 48px; height: 48px; }
    .feature-icon img { width: 56px; height: 56px; }
    .partners { width: 100%; max-width: 100%; justify-content: center; }
  }
  @media (max-width: 400px) {
    .features { gap: 0.6rem; }
    .feature { width: 56px; }
  }
</style>
