---
import logo from '../assets/image/logo-inicio.png';

const links = [
  { label: "Inicio", href: "/", icon: "home" },
  { label: "Servicios", href: "/servicios", icon: "grid" },
  { label: "Planes", href: "/planes", icon: "tag" },
  { label: "Contáctanos", href: "/contacto", icon: "mail" },
];

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---
<header class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      <img src={logo.src} alt="Naniva" />
      <span>NANIVA</span>
    </a>

    <nav class="links" id="navLinks">
      {links.map((link) => {
        const isActive = currentPath === link.href.replace(/\/$/, "");
        return (
          <a href={link.href} class={isActive ? "active" : ""}>
            {link.icon === "home" && (
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11.5 12 4l9 7.5" /><path d="M5 10v9a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1v-9" /></svg>
            )}
            {link.icon === "grid" && (
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5" /><rect x="14" y="3" width="7" height="7" rx="1.5" /><rect x="3" y="14" width="7" height="7" rx="1.5" /><rect x="14" y="14" width="7" height="7" rx="1.5" /></svg>
            )}
            {link.icon === "tag" && (
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m20.59 13.41-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82Z" /><circle cx="7" cy="7" r="1.5" fill="currentColor" stroke="none" /></svg>
            )}
            {link.icon === "mail" && (
              <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><path d="m22 6-10 7L2 6" /></svg>
            )}
            <span>{link.label}</span>
          </a>
        );
      })}
    </nav>

    <a href="https://wa.me/51908644190" target="_blank" rel="noopener noreferrer" class="demo-btn hover-pop">
      Solicitar demo
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14" /><path d="m13 6 6 6-6 6" /></svg>
    </a>

    <button class="menu-toggle" id="menuToggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <div class="menu-backdrop" id="menuBackdrop"></div>
</header>

<style>
  .nav {
    position: fixed;
    top: 1.25rem;
    left: 0;
    right: 0;
    z-index: 20;
    padding: 0 1.5rem;
  }
  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: linear-gradient(135deg, #0b1220, #16233d);
    border-radius: 999px;
    padding: 0.6rem 0.75rem 0.6rem 1.25rem;
    box-shadow: 0 10px 30px rgba(2, 6, 23, 0.35);
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
    text-decoration: none;
  }
  .brand img {
    height: 34px;
    width: auto;
    object-fit: contain;
  }
  .brand span {
    color: white;
    font-weight: 800;
    font-size: 1.10rem;
    letter-spacing: 0.02em;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }
  .links a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #cbd5e1;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.92rem;
    padding-bottom: 0.35rem;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease;
  }
  .links a:hover {
    color: #2563eb;
    border-bottom-color: #2563eb;
  }
  .links a.active {
    color: #3b82f6;
    border-bottom-color: #3b82f6;
  }
  .demo-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    color: white;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.25rem;
    border-radius: 999px;
    text-decoration: none;
    white-space: nowrap;
  }
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    border: none;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    margin-left: auto;
    position: relative;
    z-index: 2;
    flex-shrink: 0;
  }
  .menu-toggle span {
    display: block;
    width: 20px;
    height: 2px;
    background: white;
    margin: 0 auto;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  .menu-toggle.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .menu-toggle.open span:nth-child(2) { opacity: 0; }
  .menu-toggle.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  .menu-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.45);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
    z-index: 0;
  }
  .menu-backdrop.open {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 900px) {
    .links { gap: 1.1rem; }
    .links a span { display: none; }
  }

  @media (max-width: 768px) {
    .demo-btn { display: none; }
    .menu-toggle { display: flex; }
    .links {
      display: flex;
      position: fixed;
      top: 0;
      right: 0;
      height: 100vh;
      width: min(80vw, 320px);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      background: #0b1220;
      box-shadow: -10px 0 40px rgba(15,23,42,0.35);
      transform: translateX(100%);
      transition: transform 0.35s ease;
      padding-top: 6rem;
      justify-content: flex-start;
      z-index: 1;
    }
    .links.open {
      transform: translateX(0);
    }
    .links a {
      width: 100%;
      margin-top: 0;
      padding: 1.25rem 1.75rem;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      border-radius: 0;
      font-size: 1.1rem;
    }
    .links a span { display: inline; }
    .links a:last-child { border-bottom: none; }
    .links a.active { border-bottom-color: rgba(255,255,255,0.08); }
  }
</style>

<script>
  const toggle = document.getElementById("menuToggle");
  const links = document.getElementById("navLinks");
  const backdrop = document.getElementById("menuBackdrop");

  function closeMenu() {
    links?.classList.remove("open");
    toggle?.classList.remove("open");
    backdrop?.classList.remove("open");
    toggle?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", () => {
    const isOpen = links?.classList.toggle("open");
    toggle.classList.toggle("open");
    backdrop?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    document.body.style.overflow = isOpen ? "hidden" : "";
  });

  backdrop?.addEventListener("click", closeMenu);
  links?.querySelectorAll("a").forEach((a) => a.addEventListener("click", closeMenu));
</script>
