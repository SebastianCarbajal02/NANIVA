---
import bgFacturacion from '../assets/image/FACTURA5-05.webp';
import bgErpNaniva   from '../assets/image/ERP-03.webp';
import bgCatalogo from '../assets/image/plan-catalogo.webp';
import bgRestaurante from '../assets/image/plan-restaurante.webp';
import bgSoftware from '../assets/image/plan-software.webp';
import iconFacturacion from '../assets/image/icon-naniva-facturacion.webp';
import iconCatalogo from '../assets/image/icon-naniva-catalogo.webp';
import iconRestaurante from '../assets/image/icon-naniva-restaurante.webp';
import iconIntegraciones from '../assets/image/icon-naniva-5.webp';
import iconDesarrollo from '../assets/image/icon-naniva-6.webp';
import iconNaniva from '../assets/image/icon-naniva-ia-2.webp';
import iconErp from '../assets/image/icon-erp-2.webp';
import iconEcomerce from '../assets/image/icon-ecomerce-2.webp';
import imgNaniviaIa3 from '../assets/image/img-naniva-ia-3.webp';
import imgEcomerce4 from '../assets/image/ECOMERC-04.webp';
import imgImplem1 from '../assets/image/IMPLEM1-06.webp';


function iconSvg(name: string, color: string = "white", size = 22) {
  const icons: Record<string, string> = {
    cpu: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><path d="M15 2v2M9 2v2M15 20v2M9 20v2M20 15h2M20 9h2M2 15h2M2 9h2"/></svg>`,
    package: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
    cart: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 2-1.58l1.65-7.42H5.12"/></svg>`,
    receipt: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M8 7h8M8 11h8M8 15h5"/></svg>`,
    bag: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 7 8 3h8l2 4"/><rect x="3" y="7" width="18" height="14" rx="2"/><path d="M8 11a4 4 0 0 0 8 0"/></svg>`,
    utensils: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2v7a2 2 0 0 0 4 0V2M8 9v13M18 2c-2 2-2 5-2 8s2 4 2 4v9"/></svg>`,
    link: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 17H7A5 5 0 0 1 7 7h2M15 7h2a5 5 0 1 1 0 10h-2M8 12h8"/></svg>`,
    gear: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M4.9 4.9l2.1 2.1M17 17l2.1 2.1M4.9 19.1L7 17M17 7l2.1-2.1"/></svg>`,
    users: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    cloud: `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h.79a4.5 4.5 0 1 1 0 9Z"/></svg>`,
  };
  return icons[name] ?? "";
}

const mainServices = [
  {
    icon: "cpu",
    iconImg: iconNaniva,
    iconBgColor: "#a855f7",
    accent: "#9333ea",
    badge: { icon: "★", text: "DIFERENCIADOR", bg: "#f3e8ff", color: "#9333ea" },
    eyebrow: "INTELIGENCIA ARTIFICIAL",
    title: "Naniva IA",
    desc: "Tu analista inteligente que entiende tus datos y te ayuda a crecer.",
    items: ["Detecta problemas antes que pasen", "Encuentra oportunidades de venta", "Prioriza lo más importante", "Recomienda acciones claras"],
    cta: "Descubrir IA →",
    mockup: "ia",
  },
  {
    icon: "package",
    iconImg: iconErp,
    iconBgColor: "#3b82f6",
    accent: "#2563eb",
    badge: { icon: "★", text: "MÁS ELEGIDO", bg: "#dbeafe", color: "#2563eb" },
    eyebrow: "ERP EMPRESARIAL",
    title: "ERP Naniva",
    desc: "Controla toda tu empresa desde un solo lugar.",
    items: ["Ventas e Inventario", "Compras", "Clientes", "Reportes en tiempo real"],
    cta: "Ver ERP →",
    mockup: "erp",
  },
  {
    icon: "cart",
    iconImg: iconEcomerce,
    iconBgColor: "#22c55e",
    accent: "#16a34a",
    badge: { icon: "🚀", text: "PARA CRECER", bg: "#dcfce7", color: "#16a34a" },
    eyebrow: "ECOMMERCE",
    title: "Naniva Ecommerce",
    desc: "Vende online conectado a tu ERP.",
    items: ["Tienda online personalizada", "Pasarelas de pago", "Sincronizado con tu inventario"],
    cta: "Ver Ecommerce →",
    mockup: "ecommerce",
  },
];

const modules = [
  {
    icon: "receipt",
    iconImg: iconFacturacion,
    iconBgColor: "#ff7a00",
    accent: "#f97316",
    title: "Naniva Facturación",
    desc: "Factura en segundos, sin errores y cumpliendo SUNAT.",
    items: ["Facturas y Boletas", "Guías de Remisión", "Integrado con SUNAT"],
    cta: "Ver Facturación →",
    mockupImg: bgFacturacion,
    mockupClass: "module-mockup-facturacion",
  },
  {
    icon: "bag",
    iconImg: iconCatalogo,
    iconBgColor: "#22c55e",
    accent: "#16a34a",
    title: "Naniva Catálogo",
    desc: "Vende por WhatsApp automáticamente.",
    items: ["Catálogo interactivo", "Pedidos por WhatsApp", "Códigos QR"],
    cta: "Ver Catálogo →",
    mockupImg: bgCatalogo,
    mockupClass: "module-mockup-catalogo",
  },
  {
    icon: "utensils",
    iconImg: iconRestaurante,
    iconBgColor: "#a855f7",
    accent: "#9333ea",
    title: "Naniva Restaurante",
    desc: "Todo lo que necesitas para operar tu restaurante.",
    items: ["POS Restaurante", "Mesas", "Cocina", "Delivery"],
    cta: "Ver Restaurante →",
    mockupImg: bgRestaurante,
    mockupClass: "module-mockup-restaurante",
  },
  {
    icon: "link",
    iconImg: iconIntegraciones,
    accent: "#2563eb",
    title: "Integraciones Naniva",
    desc: "Conecta tus herramientas y automatiza tu negocio.",
    items: ["WhatsApp Business", "Pasarelas de pago", "Courier y envíos", "+50 integraciones"],
    cta: "Ver Integraciones →",
    mockupImg: imgImplem1,
    mockupClass: "module-mockup-integraciones",
  },
  {
    icon: "gear",
    iconImg: iconDesarrollo,
    accent: "#475569",
    title: "Desarrollo a Medida",
    desc: "Desarrollamos el sistema que tu empresa necesita.",
    items: ["Análisis personalizado", "Desarrollo a la medida", "Soporte continuo"],
    cta: "Cotizar proyecto →",
    mockupImg: bgSoftware,
    mockupClass: "module-mockup-software",
  },
];

const stats = [
  { icon: "users", bg: "#ede9fe", color: "#7c3aed", value: "+200 empresas", desc: "confían en Naniva y crecen cada día." },
  { icon: "link", bg: "#dcfce7", color: "#16a34a", value: "+50 integraciones", desc: "con tus herramientas favoritas." },
  { icon: "cloud", bg: "#dbeafe", color: "#2563eb", value: "100% en la nube", desc: "Accede desde cualquier lugar, en cualquier dispositivo." },
  { icon: "cpu", bg: "#f3e8ff", color: "#9333ea", value: "IA integrada", desc: "Inteligencia Artificial en toda la plataforma." },
];
---

<section id="servicios" class="services">
  <div class="container">
    <div class="tag">NUESTRAS SOLUCIONES</div>
    <h2>Todo lo que tu negocio necesita <span class="highlight">en un solo lugar</span></h2>
    <p class="subtitle">Soluciones diseñadas para impulsar tu crecimiento y simplificar tu gestión diaria.</p>

    <div class="main-grid">
      {mainServices.map((s, i) => (
        <article class="main-card reveal hover-lift" style={`transition-delay:${i * 0.1}s`}>
          <div class="main-card-body">
            <div class="main-card-content">
              <div class="icon-row">
                {s.iconImg ? (
                  <img src={s.iconImg.src} alt="" class="icon icon-bounce icon-plain" />
                ) : (
                  <div class="icon icon-bounce" style={`background:${s.accent}`} set:html={iconSvg(s.icon, "white", 30)} />
                )}
                <div class="icon-row-text">
                  <span class="card-badge-inline" style={`background:${s.badge.bg}; color:${s.badge.color}`}>
                    {s.badge.icon} {s.badge.text}
                  </span>
                  <h3>{s.title}</h3>
                  <span class="eyebrow" style={`color:${s.accent}`}>{s.eyebrow}</span>
                </div>
              </div>
              <p class="desc">{s.desc}</p>
              <ul>
                {s.items.map((item) => (
                  <li>
                    <span class="check" style={`color:${s.accent}`}>✓</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <a href="#planes" class="ver-planes hover-pop" style={`color:${s.accent}; border-color:${s.accent}`}>
                {s.cta}
              </a>
            </div>
            <div class="main-card-visual">
              {s.mockup === "ia" && (
                <div class="mockup mockup-ia-img">
                  <img src={imgNaniviaIa3.src} alt="Naniva IA" class="mockup-ia-image" />
                </div>
              )}
              {s.mockup === "erp" && (
                <div class="mockup mockup-erp-img">
                  <img src={bgErpNaniva.src} alt="ERP Naniva" class="mockup-erp-image" />
                </div>
              )}
              {s.mockup === "ecommerce" && (
                <div class="mockup mockup-ecommerce-img">
                  <img src={imgEcomerce4.src} alt="Naniva Ecommerce" class="mockup-ecommerce-image" />
                </div>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>

    <h3 class="modules-title">Complementa tu plataforma con módulos especializados</h3>
    <div class="modules-grid">
      {modules.map((m, i) => (
        <article class="module-card reveal hover-lift" style={`transition-delay:${i * 0.08}s`}>
          <div class="module-header">
            {m.iconImg ? (
              <img src={m.iconImg.src} alt="" class="icon icon-sm icon-bounce icon-plain" />
            ) : (
              <div class="icon icon-sm icon-bounce" style={`background:${m.accent}1a`} set:html={iconSvg(m.icon, m.accent, 26)} />
            )}
            <h4 style={`color:${m.accent}`}>{m.title}</h4>
          </div>
          <p class="desc">{m.desc}</p>
          <ul>
            {m.items.map((item) => (
              <li>
                <span class="check" style={`color:${m.accent}`}>✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          {m.mockupImg && <img src={m.mockupImg.src} alt="" class={`module-mockup ${m.mockupClass ?? ""}`} />}
          <a href="#planes" class="ver-planes hover-pop" style={`color:${m.accent}; border-color:${m.accent}`}>
            {m.cta}
          </a>
        </article>
      ))}
    </div>

  </div>
</section>

<style>
  .services {
    padding: 4rem 0 0;
    background: #f8fafc;
  }
  .services .container {
    max-width: 1600px;
  }
  .tag {
    text-align: center;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  h2 {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: 0.5rem;
  }
  .highlight { color: #2563eb; }
  .subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }

  .main-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .main-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }
  .icon-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .icon-row-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
  }
  .icon-row-text h3 { margin: 0; }
  .icon-row .icon { margin-bottom: 0; }
  .card-badge-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    white-space: nowrap;
  }
  .main-card-body {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .main-card-content {
    flex: 1.1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }
  .main-card-visual {
    flex: 0.9;
    min-width: 0;
  }
  .icon {
    width: 110px;
    height: 110px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    margin-bottom: 0.75rem;
  }
  .icon-sm { width: 68px; height: 68px; border-radius: 12px; }
  .icon-plain { object-fit: contain; background: transparent; }
  .icon-img-mask {
    display: block;
    width: 80%;
    height: 80%;
    mask-size: contain;
    mask-repeat: no-repeat;
    mask-position: center;
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    -webkit-mask-position: center;
  }
  .eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  h3 { font-size: 1.15rem; font-weight: 800; margin: 0.25rem 0 0.5rem; color: #0f172a; }
  .desc { color: var(--color-text-muted); font-size: 0.85rem; margin-bottom: 0.85rem; }
  ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
  li { display: flex; align-items: flex-start; gap: 0.5rem; font-size: 0.8rem; color: #334155; line-height: 1.3; }
  .check { font-weight: 700; margin-top: 0.05rem; }
  .ver-planes {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1.5px solid;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .mockup-ia-img { position: relative; padding-top: 0.5rem; }
  .mockup-ia-image { width: 100%; height: auto; display: block; }
  .mockup-ia { position: relative; padding-top: 0.5rem; }
  .mockup-tablet {
    background: #0f172a;
    border-radius: 14px;
    padding: 6px;
  }
  .mockup-tablet-screen {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  .mockup-reco {
    position: absolute;
    bottom: -1rem;
    right: -0.75rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.15);
    padding: 0.6rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 140px;
  }
  .mockup-reco-title { font-size: 0.65rem; font-weight: 700; color: #0f172a; margin-bottom: 0.1rem; }
  .mockup-reco-item { display: flex; align-items: center; gap: 0.35rem; font-size: 0.62rem; color: #334155; white-space: nowrap; }
  .dot { width: 6px; height: 6px; border-radius: 999px; flex-shrink: 0; }

  .mockup-erp-img { position: relative; padding-top: 0.5rem; }
  .mockup-erp-image { width: 100%; height: auto; display: block; }
  .mockup-ecommerce-img { position: relative; padding-top: 0.5rem; }
  .mockup-ecommerce-image { width: 100%; height: auto; display: block; }
  .mockup-erp { position: relative; padding-top: 0.5rem; }
  .mockup-laptop { background: #0f172a; border-radius: 10px; padding: 4px; }
  .mockup-laptop-screen { width: 100%; height: auto; border-radius: 6px; display: block; }
  .mockup-phone {
    position: absolute;
    bottom: -0.75rem;
    right: -0.5rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.15);
    padding: 0.5rem 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .mockup-phone-label { font-size: 0.6rem; color: var(--color-text-muted); font-weight: 600; }
  .mockup-phone-stat { font-size: 0.85rem; font-weight: 800; color: #0f172a; }
  .mockup-phone-sub { font-size: 0.6rem; color: #16a34a; font-weight: 700; }

  .mockup-ecommerce {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .mockup-head { display: flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; font-weight: 700; color: #334155; }
  .mockup-product {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 0.5rem;
  }
  .mockup-product-thumb {
    width: 36px;
    height: 36px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f1f5f9;
    border-radius: 8px;
    font-size: 1.2rem;
  }
  .mockup-product-info { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; }
  .mockup-product-name { font-size: 0.72rem; font-weight: 600; color: #0f172a; }
  .mockup-product-price { font-size: 0.72rem; font-weight: 700; color: #16a34a; }
  .mockup-add-btn {
    background: #16a34a;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 0.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: default;
  }
  .mockup-categories { display: flex; flex-direction: column; gap: 0.4rem; }
  .mockup-categories > span { font-size: 0.65rem; color: var(--color-text-muted); font-weight: 600; }
  .mockup-cat-icons { display: flex; gap: 0.5rem; font-size: 1.1rem; }

  .modules-title {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1.5rem;
  }
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
    margin-bottom: 3rem;
  }
  .module-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  .module-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }
  .module-header h4 { font-size: 0.9rem; font-weight: 700; }
  .module-mockup {
    width: 100%;
    max-width: 170px;
    height: auto;
    object-fit: contain;
    align-self: flex-end;
    margin: -1.5rem 0 0.5rem auto;
  }
  .module-mockup-facturacion {
 max-width: 210px;
  margin-top: -3rem;
  margin-right:-1rem;
  transform: translateY(-2rem)

  }
  .module-mockup-integraciones{
  max-width: 205px;
  max-height: 350px;
  margin-top: -3rem;
  margin-right:0.3rem;
  transform: translateY(-3rem)
  }
  .module-mockup-catalogo {
   max-width: 290px;
  margin-top: -0.5%;
  margin-right:-3rem;
   }
  .module-mockup-restaurante {
    max-width: 270px;
    margin-top: -3rem;
    margin-right:-3rem;
    transform: translateY(-1rem); }
  .module-mockup-software {
    max-width: 295px;
    margin-top: -2rem;
    margin-right:-4rem;
  }


  .stats-bar {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 2rem 1.5rem;
    margin-top: 3rem;

  }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }
  .stat-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .stat-icon {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
