---
import iconFactura from '../assets/image/factura.webp';
import iconCatalogo from '../assets/image/icon-plan-catalogo.webp';
import iconRestaurante from '../assets/image/icon-plan-restaurante.webp';
import iconSoftware from '../assets/image/icon-plan-software.webp';
import bgFacturacion from '../assets/image/pla-facturacion.webp';
import bgCatalogo from '../assets/image/plan-catalogo.webp';
import bgRestaurante from '../assets/image/plan-restaurante.webp';
import bgSoftware from '../assets/image/plan-software.webp';

const services = [
  {
    icon: iconFactura,
    bg: bgFacturacion,
    iconBg: "#2563eb",
    title: "Facturación Electrónica",
    desc: "Emite comprobantes electrónicos de manera rápida, segura y 100% válida.",
    items: ["Boletas y Facturas SUNAT", "Guías de Remisión", "Cotizaciones", "Inventario", "Reportes y estadísticas"],
    accent: "#2563eb",
  },
  {
    icon: iconCatalogo,
    bg: bgCatalogo,
    iconBg: "#16a34a",
    title: "Catálogo Digital",
    desc: "Muestra tus productos y recibe pedidos por WhatsApp fácilmente.",
    items: ["Catálogo interactivo", "Pedidos por WhatsApp", "Fotos ilimitadas", "Códigos QR", "Compartir enlaces"],
    accent: "#16a34a",
  },
  {
    icon: iconRestaurante,
    bg: bgRestaurante,
    iconBg: "#9333ea",
    title: "Sistema Restaurante",
    desc: "Gestiona tu restaurante de forma eficiente y aumenta sus ventas.",
    items: ["Punto de Venta (POS)", "Gestión de mesas", "Delivery", "Cocina y comandas", "Inventario", "Reportes"],
    accent: "#9333ea",
  },
  {
    icon: iconSoftware,
    bg: bgSoftware,
    iconBg: "#2563eb",
    title: "Implementación a Medida para tu Negocio",
    desc: "Desarrollamos e implementamos soluciones personalizadas que se adaptan exactamente a tus necesidades.",
    items: ["Análisis personalizado", "Desarrollo a la medida", "Integración con|sistemas existentes", "Capacitación y soporte|continuo"],
    accent: "#2563eb",
  },
];

const whyChoose = [
  { icon: "⏱️", title: "Implementación en minutos", desc: "Comienza a usarlo rápido y fácil." },
  { icon: "🛡️", title: "Seguridad total", desc: "Tus datos protegidos con encriptación SSL." },
  { icon: "☁️", title: "Sistema en la nube", desc: "Accede desde cualquier lugar y dispositivo." },
  { icon: "📱", title: "Acceso desde celular", desc: "Gestiona tu negocio desde dónde estés." },
  { icon: "📈", title: "Reportes en tiempo real", desc: "Toma mejores decisiones con información al instante." },
  { icon: "⚙️", title: "Soporte personalizado", desc: "Te acompañamos en cada paso de tu crecimiento." },
];
---
<section id="servicios" class="services">
  <div class="container">
    <div class="tag">NUESTRAS SOLUCIONES</div>
    <h2>Todo lo que tu negocio necesita en un solo lugar</h2>
    <p class="subtitle">Soluciones diseñadas para impulsar tu crecimiento y simplificar tu gestión diaria.</p>

    <div class="grid">
      {services.map((s, i) => (
        <article class="card reveal hover-lift" style={`transition-delay:${i * 0.1}s`}>
          <div class={i === 3 ? "card-header wrap" : "card-header"}>
            <div class="icon icon-bounce" style={`background:${s.iconBg}`}>
              <img src={s.icon.src} alt={s.title} />
            </div>
            <h3>{s.title}</h3>
          </div>
          <p class="desc">{s.desc}</p>
          <div class="body">
            <ul class={i === 3 ? "wrap" : ""}>
              {s.items.map((item) => (
                <li>
                  <span class="check" style={`color:${s.accent}`}>✓</span>
                  <span>{item.split("|").map((line, idx, arr) => (
                    idx < arr.length - 1 ? <><span style="white-space:nowrap">{line}</span><br /></> : <span style="white-space:nowrap">{line}</span>
                  ))}</span>
                </li>
              ))}
            </ul>
            <img src={s.bg.src} alt="" class="side-img" style={
              i === 0 ? "margin-top: 1rem;margin-left: 4rem" :
              i === 1 ? "width: 260px; margin-left: 5rem;" :
              i === 2 ? "margin-left: 6rem;" :
              i === 3 ? "width: 220px; margin-left: 6rem; margin-top: -1.5rem;" : ""
            } />
          </div>
          <a href="#planes" class="ver-planes hover-pop" style={`color:${s.accent}; border-color:${s.accent}`}>
            Ver Planes →
          </a>
        </article>
      ))}
    </div>
  </div>

  <div class="why-choose">
    <div class="container">
      <h3>¿Por qué elegir <strong>Naniva</strong>?</h3>
      <div class="why-grid">
        {whyChoose.map((w, i) => (
          <div class="why-item reveal" style={`transition-delay:${i * 0.08}s`}>
            <div class="why-icon icon-bounce">{w.icon}</div>
            <h4>{w.title}</h4>
            <p>{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .services {
    padding: 4rem 0 0;
    background: #f8fafc;
  }
  .services .container {
    max-width: 100%;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
  }
  .tag {
    text-align: center;
    color: var(--color-primary);
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin-bottom: 0.75rem;
  }
  h2 {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.5rem;
  }
  .subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 3rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }
  @media (max-width: 1000px) {
    .grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }
  }
  @media (max-width: 700px) {
    .services .container { padding-left: 1rem; padding-right: 1rem; }
    .body { flex-direction: column; }
    li, ul.wrap li:nth-child(1), ul.wrap li:nth-child(2) { white-space: normal; }
    .body ul { flex: none; width: 100%; }
    .side-img {
      width: 160px !important;
      max-width: 70% !important;
      margin: 1rem auto 0 !important;
    }
    h3 { white-space: normal; }
    .card-header.wrap h3 { font-size: 1rem; }
  }
  .card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius);
    padding: 1rem 1.5rem;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .body {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .body ul {
    flex: 1.4;
    min-width: 0;
    margin-bottom: 0;
  }
  .side-img {
    width: 220px;
    max-width: 100%;
    flex: 0.9;
    height: auto;
    object-fit: contain;
    flex-shrink: 0;
    align-self: center;
  }
  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .card-header.wrap {
    align-items: flex-start;
  }
  .card-header.wrap h3 {
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
  }
  .icon {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
  }
  .icon img {
    width: 40px;
    height: 40px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  h3 { font-size: 0.95rem; margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; min-width: 0; flex: 1; }
  .desc { color: var(--color-text-muted); font-size: 0.8rem; margin-bottom: 1rem; }
  ul { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1rem; }
  li { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: #334155; white-space: nowrap; }
  ul.wrap li { white-space: normal; align-items: flex-start; line-height: 1.4; }
  ul.wrap li .check { margin-top: 0.1rem; }
  ul.wrap li:nth-child(1),
  ul.wrap li:nth-child(2) { white-space: nowrap; }
  .check { font-weight: 700; }
  .placeholder {
    height: 140px;
    border: 1px dashed #cbd5e1;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #94a3b8;
    font-size: 0.8rem;
    margin-bottom: 1rem;
    background: #f1f5f9;
  }
  .plan-header-icon {
    width: 100%;
    height: 100px;
    object-fit: contain;
    margin-bottom: 1rem;
    border-radius: 8px;
  }
  .ver-planes {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1.5px solid;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    width: fit-content;
  }
  .why-choose {
    margin-top: 4rem;
    background: #eef4ff;
    padding: 3rem 1rem;
  }
  .why-choose h3 {
    text-align: center;
    font-size: 1.4rem;
    margin-bottom: 2.5rem;
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 2rem;
    text-align: center;
  }
  .why-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.4rem;
    filter: grayscale(1) brightness(1.3) sepia(1) hue-rotate(185deg) saturate(5) drop-shadow(0 4px 6px rgba(0,0,0,0.2));
  }
  .why-item h4 { font-size: 0.95rem; margin-bottom: 0.4rem; }
  .why-item p { font-size: 0.8rem; color: var(--color-text-muted); }
</style>
