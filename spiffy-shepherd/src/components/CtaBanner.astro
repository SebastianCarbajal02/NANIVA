---
export interface Props {
  whatsappLink?: string;
}
const { whatsappLink = "https://wa.me/51999999999" } = Astro.props;
---
<section class="cta">
  <div class="container reveal">
    <div class="rocket float-anim">🚀</div>
    <div class="copy">
      <h2>¿Listo para digitalizar tu negocio?</h2>
      <p>Empieza hoy mismo y lleva el control total de tus ventas, inventarios y clientes.</p>
    </div>
    <a href={whatsappLink} class="btn-whatsapp hover-pop pulse-ring whatsapp" target="_blank" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="#25D366" aria-hidden="true">
        <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38a9.9 9.9 0 0 0 4.74 1.21h.01c5.46 0 9.91-4.45 9.91-9.92 0-2.65-1.03-5.14-2.9-7.01A9.86 9.86 0 0 0 12.04 2m0 1.67a8.2 8.2 0 0 1 5.83 2.42 8.19 8.19 0 0 1 2.41 5.82c0 4.55-3.7 8.25-8.25 8.25a8.25 8.25 0 0 1-4.2-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.2 8.2 0 0 1-1.26-4.39c0-4.55 3.7-8.24 8.26-8.24m-4.53 4.7c-.16 0-.42.06-.64.3-.22.24-.85.83-.85 2.03 0 1.2.87 2.35.99 2.51.12.16 1.7 2.7 4.19 3.7 2.07.82 2.49.66 2.94.62.45-.04 1.45-.6 1.65-1.17.2-.58.2-1.08.14-1.18-.06-.1-.22-.16-.46-.28-.24-.12-1.45-.72-1.67-.8-.22-.08-.39-.12-.55.12-.16.24-.63.8-.78.97-.14.16-.28.18-.52.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.11-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.34-.76-1.83-.2-.48-.4-.42-.55-.42h-.47z"/>
      </svg>
      Hablar por WhatsApp
    </a>
  </div>
</section>

<style>
  .cta {
    background: linear-gradient(135deg, #2563eb, #3b82f6);
    padding: 3rem 1.5rem;
  }
  .cta .container {
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .rocket { font-size: 3.5rem; flex-shrink: 0; }
  .copy { flex: 1; min-width: 260px; color: white; }
  .copy h2 { font-size: clamp(1.3rem, 2.5vw, 1.6rem); margin-bottom: 0.5rem; }
  .copy p { opacity: 0.9; font-size: 0.95rem; }
  .btn-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: #16a34a;
    padding: 0.75rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .cta .container { justify-content: center; text-align: center; }
    .copy { text-align: center; min-width: 100%; }
    .btn-whatsapp { width: 100%; justify-content: center; }
  }
</style>
