---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Producto",
    links: ["Facturación Electrónica", "Catálogo Digital", "Sistema Restaurante", "Planes"],
  },
  {
    title: "Recursos",
    links: ["Términos y condiciones", "Política de privacidad"],
  },
];
---
