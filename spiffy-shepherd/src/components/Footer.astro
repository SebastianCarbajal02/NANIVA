        </div>
      </div>
      {columns.map((col) => (
        <div class="links">
          <h4>{col.title}</h4>
          {col.links.map((link) => <a href="#">{link}</a>)}
        </div>
      ))}
      <div class="contact-col">
        <h4>Contacto</h4>
        <p>+51 908 644 190</p>
        <p>nanivatechnologies@gmail.com</p>
        <p class="nowrap">Lun - Vie 9:00 am - 6:00 pm</p>
        <p>Calle Manrique de Luna 168, San Miguel, Lima, Peru</p>
      </div>
      <div class="reclamos">
        <span>LIBRO DE RECLAMACIONES</span>
        <span class="reclamos-icon">📖</span>
      </div>
    </div>
    <div class="bottom">
      <p>&copy; {year} Naniva. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
footer {
  background: #111827;
  color: #9ca3af;
  padding: 3rem 1rem 2rem;
}
footer .container {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
}
.grid {
  display: flex;
  gap: 2rem;
  margin-bottom: 2.5rem;
  justify-content: space-between;
  flex-wrap: nowrap;
}
.brand {
  flex: 1.8;
  min-width: 200px;
}
.brand strong {
  font-size: 1.4rem;
  color: white;
  display: block;
  margin-bottom: 0.75rem;
  letter-spacing: 0.02em;
}
.brand p {
  font-size: 0.85rem;
  line-height: 1.6;
  margin-bottom: 1rem;
}
.socials {
  display: flex;
  gap: 0.6rem;
}
.social {
  width: 30px;
  height: 30px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
}
.facebook { background: #1877f2; }
.instagram { background: radial-gradient(circle at 30% 110%, #fdf497, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285AEB 90%); }
.tiktok { background: #000; }
.youtube { background: #ff0000; }
.whatsapp { background: #25D366; }
.links {
  flex: 1;
  min-width: 100px;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}
.links h4 {
  color: white;
  margin-bottom: 0.25rem;
  font-size: 0.9rem;
}
.links a {
  color: #9ca3af;
  text-decoration: none;
  font-size: 0.85rem;
  transition: color 0.2s;
}
.links a:hover { color: white; }
.contact-col {
  flex: 1.8;
  min-width: 200px;
}
.contact-col h4 {
  color: white;
  margin-bottom: 0.6rem;
  font-size: 0.9rem;
}
.contact-col p {
  font-size: 0.85rem;
  margin-bottom: 0.5rem;
  line-height: 1.5;
}
.contact-col .nowrap { white-space: nowrap; }
.reclamos {
  flex: 0.8;
  min-width: 80px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.4rem;
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-align: center;
}
.reclamos-icon { font-size: 4rem; }
.bottom {
  border-top: 1px solid #1f2937;
  padding-top: 1.5rem;
  text-align: center;
  font-size: 0.8rem;
}
@media (max-width: 900px) {
  .grid { flex-wrap: wrap; }
  .links { min-width: 140px; }
}
@media (max-width: 500px) {
  .grid { flex-direction: column; }
}
</style>